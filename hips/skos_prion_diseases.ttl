    skos:prefLabel "Enfermedades por priones"@es ;
    skos:prefLabel "Encefalopatie Spongiformi Trasmissibili"@it ;
    skos:prefLabel "призонні захворювання"@ua ;
    skos:prefLabel "Прионовые болезни"@ru ;
    skos:prefLabel "朊蛋白病"@ch ;
    skos:prefLabel "Prionziekten"@nl .
