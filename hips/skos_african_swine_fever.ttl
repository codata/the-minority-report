ex:african_swine_fever a skos:Concept ;
    skos:prefLabel "African Swine Fever"@en ;
    skos:definition "African swine fever (ASF) is a highly contagious viral disease of domestic and wild pigs, whose mortality rate can reach 100%. It is not a danger to human health, but it has devastating effects on pig populations and the farming economy. (WOAH, no date)."@en ;
