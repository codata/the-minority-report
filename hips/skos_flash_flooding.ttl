    skos:prefLabel "Inundación Flash"@es ;
    skos:prefLabel "inondazione flash"@it ;
    skos:prefLabel "Раптова повінь"@ua ;
    skos:prefLabel "быстрый паводок"@ru ;
    skos:prefLabel "突发洪水"@ch ;
    skos:prefLabel "Plotselinge waterstroming"@nl .
