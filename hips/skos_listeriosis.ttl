@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://theminorityreport.org/vocab/> .

ex:listeriosis a skos:Concept ;
    skos:prefLabel "Listeriosis"@en ;
    skos:definition "Listeriosis is a foodborne infection caused by the bacteriumListeria monocytogeneswhich can be invasive (the more serious form of the disease) or non-invasive (the milder form of the disease). Listeriosis outbreaks occur in all countries and can be a significant public health concern (WHO, 2018)."@en ;
    skos:prefLabel "Listeriose"@fr ;
    skos:prefLabel "Listeriosis"@es ;
    skos:prefLabel "Listeriosi"@it ;
    skos:prefLabel "лістеріоз"@ua ;
    skos:prefLabel "Листериоз"@ru ;
    skos:prefLabel "李斯特菌病"@ch ;
    skos:prefLabel "Listeriose"@nl .
