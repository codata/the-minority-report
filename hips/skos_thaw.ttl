ex:thaw a skos:Concept ;
    skos:prefLabel "Thaw"@en ;
    skos:definition "Thaw is the melting of snow or ice at the Earth’s surface due to a temperature rise above 0°C (WMO, 1992)."@en ;
    skos:prefLabel "dégel"@fr ;
    skos:prefLabel "deshielo"@es ;
    skos:prefLabel "disgelo"@it ;
    skos:prefLabel "відтавання"@ua ;
    skos:prefLabel "оттепель"@ru ;
    skos:prefLabel "融雪"@ch .
