ex:ground_gases_ch4_rn_etc a skos:Concept ;
    skos:prefLabel "Ground Gases (CH4, Rn, etc.)"@en ;
    skos:definition "Ground gases are natural gases generated by various processes including material decay (natural and anthropogenic) and magma bodies (adapted from UK HMRC, 2016 and USGS, no date)."@en ;
    skos:prefLabel "Gaz du sol"@fr ;
    skos:prefLabel "Gases del suelo"@es ;
    skos:prefLabel "gas del suolo"@it ;
    skos:prefLabel "Підземні гази"@ua ;
    skos:prefLabel "Подземные газы"@ru ;
    skos:prefLabel "地下气体"@ch ;
    skos:prefLabel "Grondgassen"@nl .
