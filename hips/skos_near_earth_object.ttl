@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://theminorityreport.org/vocab/> .

ex:near_earth_object a skos:Concept ;
    skos:prefLabel "Near-Earth Object"@en ;
    skos:definition "A near-Earth object (NEO) is an asteroid or comet whose trajectory brings it to within 1.3 astronomical units of the Sun and hence within 0.3 astronomical units, or approximately 45 million kilometres, of the Earth’s orbit (UN OOSA, no date)."@en ;
    skos:prefLabel "Objet proche de la Terre"@fr ;
    skos:prefLabel "Objeto cercano a la Tierra"@es ;
    skos:prefLabel "Oggetto vicino alla Terra"@it ;
    skos:prefLabel "Об'єкт, близький до Землі"@ua ;
    skos:prefLabel "Объект, близкий к Земле"@ru ;
    skos:prefLabel "近地天体"@ch ;
    skos:prefLabel "nabije aardobject"@nl .
