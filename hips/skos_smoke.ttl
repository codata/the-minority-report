@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://theminorityreport.org/vocab/> .

ex:smoke a skos:Concept ;
    skos:prefLabel "Smoke"@en ;
    skos:definition "Smoke is a suspension in the air of small particles produced by combustion (WMO, 2017)."@en ;
    skos:prefLabel "fumée"@fr ;
    skos:prefLabel "humo"@es ;
    skos:prefLabel "fumo"@it ;
    skos:prefLabel "дим"@ua ;
    skos:prefLabel "дым"@ru ;
    skos:prefLabel "烟"@ch ;
    skos:prefLabel "rook"@nl .
