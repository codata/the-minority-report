ex:safety_hazards_associated_with_oil_and_gas a skos:Concept ;
    skos:prefLabel "Safety Hazards Associated with Oil and Gas"@en ;
    skos:definition "Oil and gas extraction, and associated servicing activities involve many types of equipment and materials. Identifying and controlling hazards is critical to preventing injuries and deaths (US Department of Labor, no date)."@en ;
    skos:prefLabel "Risques de sécurité liés au pétrole et au gaz"@fr ;
    skos:prefLabel "Riesgos de seguridad asociados con el petróleo y el gas"@es ;
    skos:prefLabel "Rischi di sicurezza associati al petrolio e al gas"@it ;
    skos:prefLabel "石油和天然气相关的安全危害"@ch ;
    skos:prefLabel "Veiligheidsrisico's verbonden aan olie en gas"@nl .
