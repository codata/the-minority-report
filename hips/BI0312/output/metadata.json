      "contentUrl": "hips/BI0312/data/distribution/BI0312_Rinderpest_clean.txt",
      "encodingFormat": "text/plain",
      "sha256": "bcc545e77849f3288939ed42a475ce27c7feb4c0f6c0751c5c08daa3ab5a654e"
