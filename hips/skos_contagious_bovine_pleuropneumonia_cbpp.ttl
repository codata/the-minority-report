@prefix ex: <http://theminorityreport.org/vocab/> .

ex:contagious_bovine_pleuropneumonia_cbpp a skos:Concept ;
    skos:prefLabel "Contagious Bovine Pleuropneumonia (CBPP)"@en ;
    skos:definition "Contagious bovine pleuropneumonia (CBPP) is an infectious and contagious respiratory disease of cattle and water buffalo caused byMycoplasma mycoidessubsp.mycoides(Mmm) with a major impact on livestock production and a potential for rapid spread (WOAH, 2024a)."@en ;
    skos:prefLabel "Pneumonie contagieuse bovine"@fr ;
    skos:prefLabel "Pleuroneumonía bovina contagiosa"@es ;
    skos:prefLabel "Pleuropolmonite contagiosa bovina"@it ;
    skos:prefLabel "Контагійна плевропневмонія великої рогатої худоби"@ua ;
    skos:prefLabel "传染性牛胸膜肺炎"@ch .
