@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://theminorityreport.org/vocab/> .

ex:acid_rain a skos:Concept ;
    skos:prefLabel "Acid Rain"@en ;
    skos:definition "Acid rain is rain that, in the course of its history, has combined with chemical elements or pollutants in the atmosphere and reaches the Earth’s surface as a weak acid solution (WMO/UNESCO, 2012)."@en ;
    skos:prefLabel "pluie acide"@fr ;
    skos:prefLabel "lluvia ácida"@es ;
    skos:prefLabel "pioggia acida"@it ;
    skos:prefLabel "кислий дощ"@ua ;
    skos:prefLabel "кислотный дождь"@ru ;
    skos:prefLabel "酸雨"@ch ;
    skos:prefLabel "Zure regen"@nl .
