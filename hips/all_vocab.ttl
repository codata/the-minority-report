ex:tunnel_failure a skos:Concept ;
    skos:prefLabel "Tunnel Failure"@en ;
    skos:definition "Tunnels are artificial confined underground structures, which are used for different purposes; where, for example, collapses, fires, explosions and water ingress may damage tunnel facilities and cause injuries and human casualties, resulting in severe social harm (Adapted from Zafirovski et al., 2018 and Chien and Chao, 2021)."@en ;
