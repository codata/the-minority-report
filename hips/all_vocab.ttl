@prefix ex: <http://theminorityreport.org/vocab/> .

ex:thunderstorm a skos:Concept ;
    skos:prefLabel "Thunderstorm"@en ;
    skos:definition "A thunderstorm is defined as one or more sudden electrical discharges, manifested by a flash of light (lightning) and a sharp or rumbling sound (thunder) (WMO, no date)."@en ;
    skos:prefLabel "orage"@fr ;
    skos:prefLabel "tormenta eléctrica"@es ;
    skos:prefLabel "temporale"@it ;
    skos:prefLabel "гроза"@ua ;
    skos:prefLabel "гроза"@ru ;
    skos:prefLabel "雷暴"@ch ;
    skos:prefLabel "onweer"@nl ;
    skos:prefLabel "ukkonen"@fi ;
    skos:prefLabel "trovoada"@pt .

ex:measles a skos:Concept ;
    skos:prefLabel "Measles"@en ;
    skos:definition "Measles is a highly contagious, serious disease caused by a virus from the paramyxovirus family. It spreads easily when an infected person breathes, coughs or sneezes. It can cause severe disease, complications, and even death (adapted from WHO 2024)."@en ;
    skos:prefLabel "Rougeole"@fr ;
    skos:prefLabel "Sarampión"@es ;
    skos:prefLabel "Sarampo"@it ;
    skos:prefLabel "Кір"@ua ;
    skos:prefLabel "корь"@ru ;
    skos:prefLabel "麻疹"@ch ;
    skos:prefLabel "Mazelen"@nl .

ex:asbestos a skos:Concept ;
    skos:prefLabel "Asbestos"@en ;
    skos:definition "Asbestos is the term for a group of naturally occurring fibrous silicate minerals widely used historically in building materials and other products (WHO, 2018). All types of asbestos cause lung cancer, mesothelioma, cancer of the larynx and ovary, and asbestosis (fibrosis of the lungs) (WHO, 2018)."@en ;
    skos:prefLabel "amiante"@fr ;
    skos:prefLabel "asbesto"@es ;
    skos:prefLabel "amianto"@it ;
    skos:prefLabel "азбест"@ua ;
    skos:prefLabel "асбест"@ru ;
    skos:prefLabel "石棉"@ch ;
    skos:prefLabel "asbest"@nl .

ex:yellow_fever a skos:Concept ;
    skos:prefLabel "Yellow Fever"@en ;
    skos:definition "Yellow fever is an acute viral haemorrhagic disease transmitted by infected mosquitoes and is a high-impact high-threat disease, with risk of international spread, which represents a potential threat to global health security (WHO, 2023)."@en ;
    skos:prefLabel "fièvre jaune"@fr ;
    skos:prefLabel "fiebre amarilla"@es ;
    skos:prefLabel "febbre gialla"@it ;
    skos:prefLabel "жовта лихоманка"@ua ;
    skos:prefLabel "желтая лихорадка"@ru ;
    skos:prefLabel "黄热病"@ch ;
    skos:prefLabel "gele koorts"@nl .

ex:sea_level_rise a skos:Concept ;
    skos:prefLabel "Sea Level Rise"@en ;
    skos:definition "Sea-level change (sea-level rise / sea-level fall) refers to a change in the height of sea level, both globally and locally (relative sea-level change), at seasonal, annual, or longer time scales. It results from a change in ocean volume due to a change in the mass of water in the ocean (e.g. melting of glaciers and ice sheets), changes in ocean water density (e.g. expansion under warmer conditions), changes in the shape of ocean basins, changes in the Earth's gravitational and rotational fields, and local land subsidence or uplift (IPCC, 2019)."@en ;
    skos:prefLabel "élévation du niveau de la mer"@fr ;
    skos:prefLabel "aumento del nivel del mar"@es ;
    skos:prefLabel "innalzamento del livello del mare"@it ;
    skos:prefLabel "підвищення рівня моря"@ua ;
    skos:prefLabel "повышение уровня моря"@ru ;
    skos:prefLabel "海平面上升"@ch ;
    skos:prefLabel "zeespiegelstijging"@nl .

ex:snowmelt_flooding a skos:Concept ;
    skos:prefLabel "Snowmelt Flooding"@en ;
    skos:definition "A snowmelt flood is a significant flood rise in a river caused by the melting of snowpack accumulated during the winter (WMO, 2012)."@en ;
    skos:prefLabel "crues de fonte des neiges"@fr ;
    skos:prefLabel "inundación por derretimiento de nieve"@es ;
    skos:prefLabel "повені від танення снігу"@ua ;
    skos:prefLabel "наводнение от таяния снега"@ru ;
    skos:prefLabel "融雪洪水"@ch .

ex:ionospheric_disturbances a skos:Concept ;
    skos:prefLabel "Ionospheric Disturbances"@en ;
    skos:definition "Ionospheric disturbances refer to the state of the ionosphere characterized by irregular variations of ionospheric parameters without a systematic pattern. These disturbances can be of different spatiotemporal scales and have distinct characteristics at different geographic locations. Different ionospheric disturbances pose different risks to various applications (WMO, 1992)."@en ;
    skos:prefLabel "disturbances ionosphériques"@fr ;
    skos:prefLabel "perturbaciones ionosféricas"@es ;
    skos:prefLabel "disturbi ionosferici"@it ;
    skos:prefLabel "Іоносферні збурення"@ua ;
    skos:prefLabel "Ионосферные возмущения"@ru ;
    skos:prefLabel "电离层扰动"@ch ;
    skos:prefLabel "ionosferische verstoringen"@nl .

ex:wildfires a skos:Concept ;
    skos:prefLabel "Wildfires"@en ;
    skos:definition "Any unplanned and uncontrolled vegetation fire that, regardless of ignition source, may negatively affect social, economic or environmental values, and require suppression response or other action according to agency policy (FAO, 2024)."@en ;
    skos:prefLabel "Incendies de forêt"@fr ;
    skos:prefLabel "Incendios forestales"@es ;
    skos:prefLabel "Incendi boschivi"@it ;
    skos:prefLabel "Лесные пожары"@ru ;
    skos:prefLabel "森林火灾"@ch ;
    skos:prefLabel "bosbrand"@nl .

ex:bloodborne_viruses a skos:Concept ;
    skos:prefLabel "Bloodborne Viruses"@en ;
    skos:definition "Bloodborne viruses are viruses transmitted by direct contact with infected blood or other body fluids (adapted from WHO, 2023)."@en ;
    skos:prefLabel "virus de transmisión sanguínea"@es ;
    skos:prefLabel "Virus trasmissibili per mezzo del sangue"@it ;
    skos:prefLabel "Віруси, що передаються через кров"@ua ;
    skos:prefLabel "Вирусы, передаваемые через кровь"@ru ;
    skos:prefLabel "血源性病毒"@ch ;
    skos:prefLabel "bloedoverdraagbare virussen"@nl .

ex:coral_bleaching a skos:Concept ;
    skos:prefLabel "Coral Bleaching"@en ;
    skos:definition "Corals are subject to ‘bleaching’ when the seawater temperature is too high: they lose the symbiotic algae that give coral its colour and part of its nutrients. Severe, prolonged or repeated bleaching can lead to the death of coral colonies (United Nations, 2017)."@en ;
    skos:prefLabel "Blanchissement des coraux"@fr ;
    skos:prefLabel "Blanqueamiento de corales"@es ;
    skos:prefLabel "Sbiancamento dei coralli"@it ;
    skos:prefLabel "Обесцвечивание кораллов"@ru ;
    skos:prefLabel "珊瑚白化"@ch ;
    skos:prefLabel "Koraalverbleking"@nl .

ex:household_air_pollution a skos:Concept ;
    skos:prefLabel "Household Air Pollution"@en ;
    skos:definition "Household air pollution is pollution primarily resulting from the incomplete combustion of solid fuels (e.g. wood, dung, charcoal, coal, kerosene), resulting in the emission of potentially toxic pollutants, including particles of varying sizes, carbon monoxide (CO), nitrogen dioxide, volatile and semi-volatile organic compounds (e.g. formaldehyde and benzo[a]pyrene), methylene chloride and dioxins. It is one of the leading environmental risk factors for disease and premature death and is generated by the use of inefficient and polluting fuels and technologies in and around homes."@en ;
    skos:prefLabel "Pollution de l'air domestique"@fr ;
    skos:prefLabel "contaminación del aire interior"@es ;
    skos:prefLabel "Inquinamento dell'aria domestico"@it ;
    skos:prefLabel "Домашнє забруднення повітря"@ua ;
    skos:prefLabel "Домашнее загрязнение воздуха"@ru ;
    skos:prefLabel "家庭空气污染"@ch ;
    skos:prefLabel "Huishoudelijke luchtverontreiniging"@nl .

ex:asphyxiant_gases a skos:Concept ;
    skos:prefLabel "Asphyxiant ​​Gases"@en ;
    skos:definition "Asphyxiant gases are gases that can cause unconsciousness or death by suffocation by displacing oxygen from air. Asphyxiant gases that have no other health effects are considered as simple asphyxiants. Simple asphyxiant gases become harmful to humans at high concentrations by lowering the percentage of oxygen in air (regularly present at 21%) to 19.5% or lower. (CCOHS, 2024)"@en ;
    skos:prefLabel "Gaz asphyxiants"@fr ;
    skos:prefLabel "Gases asfixiantes"@es ;
    skos:prefLabel "Gas asfissianti"@it ;
    skos:prefLabel "Асфіксуючі гази"@ua ;
    skos:prefLabel "窒息性气体"@ch ;
    skos:prefLabel "asphyxerende gassen"@nl .

ex:marine_toxins a skos:Concept ;
    skos:prefLabel "Marine Toxins"@en ;
    skos:definition "Marine toxins (biotoxins) are naturally occurring, toxic substances, mostly caused by certain types of marine organisms such as toxic algae, but also by bacteria. These toxins can accumulate in fish and shellfish, causing significant public health concerns due to their potential to cause a wide range of adverse health effects."@en ;
    skos:prefLabel "Toxines marines"@fr ;
    skos:prefLabel "Toxinas marinas"@es ;
    skos:prefLabel "Tossine marine"@it ;
    skos:prefLabel "Морські токсини"@ua ;
    skos:prefLabel "Морские токсины"@ru ;
    skos:prefLabel "海洋毒素"@ch ;
    skos:prefLabel "Mariene toxines"@nl .

ex:biological_agents a skos:Concept ;
    skos:prefLabel "Biological Agents"@en ;
    skos:definition "Biological and toxin agents are either microorganisms like viruses, bacteria or fungi, or toxic substances produced by living organisms that are produced and released deliberately to cause disease and death in humans, animals or plants (WHO, no date)."@en ;
    skos:prefLabel "agents biologiques"@fr ;
    skos:prefLabel "agentes biológicos"@es ;
    skos:prefLabel "agenti biologici"@it ;
    skos:prefLabel "біологічні агенти"@ua ;
    skos:prefLabel "биологические агенты"@ru ;
    skos:prefLabel "生物制剂"@ch ;
    skos:prefLabel "biologische agenten"@nl .

ex:chikungunya a skos:Concept ;
    skos:prefLabel "Chikungunya"@en ;
    skos:definition "Chikungunya is a mosquito-borne viral infection caused by the chikungunya virus. It causes fever and severe arthralgia (joint pain) which is often debilitating. The disease can be endemic and epidemic in countries (WHO, 2025)."@en ;
    skos:prefLabel "Chikungunya"@fr ;
    skos:prefLabel "Chikungunya"@es ;
    skos:prefLabel "Chikungunya"@it ;
    skos:prefLabel "Чікунгунья"@ua ;
    skos:prefLabel "Чикунгунья"@ru ;
    skos:prefLabel "奇克贡热"@ch ;
    skos:prefLabel "Chikungunya"@nl .

ex:rabies a skos:Concept ;
    skos:prefLabel "Rabies"@en ;
    skos:definition "Rabies is a serious public health problem in over 150 countries and territories. It is a viral zoonotic disease that affects the central nervous system and spreads from bites, licks, and scratches from infected mammals. It is almost always fatal when clinical signs appear, killing approximately 59,000 people every year (adapted from WHO, 2024a; and WOAH no date)."@en ;
    skos:prefLabel "la rage"@fr ;
    skos:prefLabel "la rabia"@es ;
    skos:prefLabel "La rabbia"@it ;
    skos:prefLabel "бешенство"@ru ;
    skos:prefLabel "狂犬病"@ch .

ex:vaccine_preventable_diseases a skos:Concept ;
    skos:prefLabel "Vaccine-Preventable Diseases"@en ;
    skos:definition "Vaccine-preventable diseases are those infectious diseases that can be prevented by vaccination (WHO, 2019)."@en ;
    skos:prefLabel "Maladies évitables par la vaccination"@fr ;
    skos:prefLabel "Enfermedades prevenibles por vacunación"@es ;
    skos:prefLabel "malattie prevenibili dalla vaccinazione"@it ;
    skos:prefLabel "захворювання, що запобігаються вакцинацією"@ua ;
    skos:prefLabel "заболевания, предотвращаемые вакцинацией"@ru ;
    skos:prefLabel "疫苗可预防的疾病"@ch ;
    skos:prefLabel "Vaccinatiepreventabele ziekten"@nl .

ex:water_supply_failure a skos:Concept ;
    skos:prefLabel "Water Supply Failure"@en ;
    skos:definition "Water supply failure is the physical shortage or scarcity in access of water supply due to the failure of institutions to ensure a regular supply or due to a lack of adequate infrastructure (adapted from UN-Water, no date)."@en ;
    skos:prefLabel "Défaillance de l'approvisionnement en eau"@fr ;
    skos:prefLabel "Fallo del suministro de agua"@es ;
    skos:prefLabel "Interruzione dell'approvvigionamento idrico"@it ;
    skos:prefLabel "Відмова водопостачання"@ua ;
    skos:prefLabel "Сбой водоснабжения"@ru ;
    skos:prefLabel "供水故障"@ch ;
    skos:prefLabel "Waterleveringsstoring"@nl .

ex:salinity_sodicity a skos:Concept ;
    skos:prefLabel "Salinity & Sodicity"@en ;
    skos:definition "Salt-affected soils consist of saline and sodic soils. Saline soils are those with an elevated amount of soluble salts, which reduces the ability of plants to take up water from soil due to the high osmotic pressure of the soil solution (FAO, 1985)."@en ;
    skos:prefLabel "Salinité et Sodicité"@fr ;
    skos:prefLabel "salinidad y sodicidad"@es ;
    skos:prefLabel "salinità e sodicità"@it ;
    skos:prefLabel "солоність і содність"@ua ;
    skos:prefLabel "соленость и содовость"@ru ;
    skos:prefLabel "盐度和钠碱度"@ch ;
    skos:prefLabel "zoutgehalte en sodiciteit"@nl .

ex:rail_accident a skos:Concept ;
    skos:prefLabel "Rail Accident"@en ;
    skos:definition "A rail accident is a sudden event or a specific chain of such events (occurring during train operation) which has harmful consequences (United Nations, European Union and the International Transport Forum at the OECD, 2019)."@en ;
    skos:prefLabel "accident ferroviaire"@fr ;
    skos:prefLabel "accidente ferroviario"@es ;
    skos:prefLabel "incidente ferroviario"@it ;
    skos:prefLabel "залізнична аварія"@ua ;
    skos:prefLabel "железнодорожная авария"@ru ;
    skos:prefLabel "铁路事故"@ch ;
    skos:prefLabel "treinongeval"@nl .

ex:hepatitis_a a skos:Concept ;
    skos:prefLabel "Hepatitis A"@en ;
    skos:definition "Hepatitis A is an acute vaccine-preventable viral liver disease and can cause mild to severe illness. Hepatitis A occurs sporadically and in epidemics worldwide, with a tendency for cyclic recurrences, as the virus persists in the environment and can withstand food production processes routinely used to inactivate or control bacterial pathogens (WHO, 2025a)."@en ;
    skos:prefLabel "Hépatite A"@fr ;
    skos:prefLabel "Hepatitis A"@es ;
    skos:prefLabel "Epatite A"@it ;
    skos:prefLabel "Гепатит A"@ua ;
    skos:prefLabel "Гепатит А"@ru ;
    skos:prefLabel "甲型肝炎"@ch ;
    skos:prefLabel "Hepatitis A"@nl .

ex:saltwater_intrusion a skos:Concept ;
    skos:prefLabel "Saltwater Intrusion"@en ;
    skos:definition "Seawater intrusion is the process by which saltwater infiltrates a coastal aquifer, leading to contamination of fresh groundwater (Prince Edward Island Department of Environment, Labour and Justice, 2011)."@en ;
    skos:prefLabel "intrusion saline"@fr ;
    skos:prefLabel "intrusión salina"@es ;
    skos:prefLabel "intrusione salina"@it ;
    skos:prefLabel "засолення ґрунтових вод"@ua ;
    skos:prefLabel "проникновение соленой воды"@ru ;
    skos:prefLabel "海水入侵"@ch ;
    skos:prefLabel "zoutwaterintrusie"@nl .

ex:west_nile_fever a skos:Concept ;
    skos:prefLabel "West Nile Fever"@en ;
    skos:definition "West Nile virus disease is a potentially fatal neurological disease caused by a virus transmitted through the bites of infected mosquitoes. The virus is a member of theflavivirusgenus and belongs to the Japanese encephalitis antigenic complex of the family Flaviviridae (WHO, 2017)."@en ;
    skos:prefLabel "Fièvre du Nil occidental"@fr ;
    skos:prefLabel "Fiebre del Nilo Occidental"@es ;
    skos:prefLabel "Febbre del Nilo Occidentale"@it ;
    skos:prefLabel "Лихоманка Західного Нілу"@ua ;
    skos:prefLabel "Лихорадка Западного Нила"@ru ;
    skos:prefLabel "西尼罗河热"@ch ;
    skos:prefLabel "West-Nijlkoorts"@nl .

ex:mining_hazards a skos:Concept ;
    skos:prefLabel "Mining Hazards"@en ;
    skos:definition "Mining hazards may cause major environmental and health impacts such as pollution of water bodies, degradation of forest resources, depletion of soil nutrients, destruction of wildlife habitat, and threats to human health. (adapted from UNDP and UN Environment, 2018)."@en ;
    skos:prefLabel "Risques miniers"@fr ;
    skos:prefLabel "Riesgos mineros"@es ;
    skos:prefLabel "Rischi minerari"@it ;
    skos:prefLabel "Гірничі ризики"@ua ;
    skos:prefLabel "采矿危害"@ch ;
    skos:prefLabel "Mijnbouwhazards"@nl .

ex:sand_encroachment a skos:Concept ;
    skos:prefLabel "Sand Encroachment"@en ;
    skos:definition "Sand encroachment is the accumulation of wind-borne sand. It commonly affects coasts, watercourses, and both cultivated and uncultivated land, typically occurring in arid to semi-arid regions. As sand accumulations move, they can bury towns, roads, oases, crops, market gardens, irrigation channels, and dams, leading to significant material and socioeconomic damage (cf. FAO, 2010)."@en ;
    skos:prefLabel "envahissement de sable"@fr ;
    skos:prefLabel "avanzamiento de arena"@es ;
    skos:prefLabel "Invasione di sabbia"@it ;
    skos:prefLabel "Зано́с песка"@ru ;
    skos:prefLabel "风沙侵袭"@ch ;
    skos:prefLabel "Zandverstuiving"@nl .

ex:violence a skos:Concept ;
    skos:prefLabel "Violence"@en ;
    skos:definition "Violence is a social phenomenon that involves forceful acts or behaviour that are intended to cause harm. The injury or damage inflicted by violence to an individual or collective group may be physical, psychological, sexual, or deprivation, or combined. Violence is both intentional and forceful (Adapted from Jacquette, 2013)."@en ;
    skos:prefLabel "Violence"@fr ;
    skos:prefLabel "Violencia"@es ;
    skos:prefLabel "Violenza"@it ;
    skos:prefLabel "Насильство"@ua ;
    skos:prefLabel "Насилие"@ru ;
    skos:prefLabel "暴力"@ch ;
    skos:prefLabel "Geweld"@nl .

ex:air_transportation_accident a skos:Concept ;
    skos:prefLabel "Air Transportation Accident"@en ;
    skos:definition "An air transportation accident is defined as an occurrence associated with the operation of an aircraft which takes place between the time any person boards the aircraft with the intention of flight until such time as all such persons have disembarked, in which one of the following applies: a person is fatally or seriously injured, the aircraft sustains damage or structural failure, and the aircraft is missing or is completely inaccessible (United Nations, European Union, the International Transport Forum at the OECD, 2019:119)."@en ;
    skos:prefLabel "Accident de transport aérien"@fr ;
    skos:prefLabel "accidente de aviación"@es ;
    skos:prefLabel "Accidente di trasporto aereo"@it ;
    skos:prefLabel "Авиационное происшествие"@ru ;
    skos:prefLabel "航空运输事故"@ch ;
    skos:prefLabel "Luchtvaartongeval"@nl .

ex:gravitational_mass_movement_landslide a skos:Concept ;
    skos:prefLabel "Gravitational Mass Movement (‘Landslide’)"@en ;
    skos:definition "A gravitational mass movement (‘landslide’) is the downslope movement of soil, rock and organic materials under the effects of gravity, which occurs when the gravitational driving forces exceed the frictional resistance of the material resisting on the slope. Such movements may be terrestrial or submarine (GH0306) (cf. Cruden and Varnes, 1996)."@en ;
    skos:prefLabel "glissement de terrain"@fr ;
    skos:prefLabel "deslizamiento de tierra"@es ;
    skos:prefLabel "scorrimento di massa"@it ;
    skos:prefLabel "зсув ґрунту"@ua ;
    skos:prefLabel "оползень"@ru ;
    skos:prefLabel "滑坡"@ch .

ex:diarrhoeal_diseases a skos:Concept ;
    skos:prefLabel "Diarrhoeal Diseases"@en ;
    skos:definition "Diarrhoeal diseases are infectious diseases, contaminants and other causes of diarrhoea. Diarrhoea is defined as the passage of three or more loose or liquid stools per day, or more frequently than is normal for the individual. Diarrhoeal disease is the third leading cause of death in children 1–59 months of age. It is both preventable and treatable. (WHO, 2024a)."@en ;
    skos:prefLabel "Maladies diarrhéiques"@fr ;
    skos:prefLabel "Enfermedades diarreicas"@es ;
    skos:prefLabel "Malattie diarroiche"@it ;
    skos:prefLabel "діарейні захворювання"@ua ;
    skos:prefLabel "диарейные заболевания"@ru ;
    skos:prefLabel "腹泻疾病"@ch ;
    skos:prefLabel "diarreeziekten"@nl .

ex:ammonia a skos:Concept ;
    skos:prefLabel "Ammonia"@en ;
    skos:definition "Ammonia (NH3) is a colourless acrid-smelling reactive gas at ambient temperature and pressure and is considered a significant public health hazard (WHO, 1986; PHE, 2019)."@en ;
    skos:prefLabel "ammoniaque"@fr ;
    skos:prefLabel "amoníaco"@es ;
    skos:prefLabel "ammoniaca"@it ;
    skos:prefLabel "амоніак"@ua ;
    skos:prefLabel "аммиак"@ru ;
    skos:prefLabel "氨"@ch ;
    skos:prefLabel "ammoniak"@nl .

ex:air_pollution_point_source a skos:Concept ;
    skos:prefLabel "Air Pollution (Point Source)"@en ;
    skos:definition "A point source of air pollution is an identifiable stationary location or fixed facility from which air pollutants are released, which may be human-made or natural in origin (adapted from Kibble and Harrison, 2005; Dunne et al., 2014)."@en ;
    skos:prefLabel "Pollution de l'air (source ponctuelle)"@fr ;
    skos:prefLabel "Contaminación del aire (fuente puntual)"@es ;
    skos:prefLabel "Inquinamento dell'aria (fonte puntuale)"@it ;
