    skos:prefLabel "ijsdamoverstromingen inclusief drijfgoed"@nl .

ex:plastic_waste a skos:Concept ;
    skos:prefLabel "Plastic Waste"@en ;
    skos:definition "Plastic Waste is defined as any discarded plastic (organic, or synthetic, material derived from polymers, resins or cellulose) generated by any industrial process, or by consumers. (Source: GEMET/APD)."@en ;
