ex:diphtheria a skos:Concept ;
    skos:prefLabel "Diphtheria"@en ;
    skos:definition "Diphtheria is a widespread severe infectious disease caused by the bacterium Corynebacterium diphtheriae and the toxin they produce. It is a potentially life-threatening, vaccine-preventable disease that primarily affects the throat and upper airways and has the potential for epidemics (WHO, 2024a)."@en ;
    skos:prefLabel "diphtherie"@fr ;
