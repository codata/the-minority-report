    skos:prefLabel "pyroclastische dichtheidsstroom"@nl .

ex:pesticides a skos:Concept ;
    skos:prefLabel "Pesticides"@en ;
    skos:definition "Pesticide means any substance, or mixture of substances of chemical or biological ingredients intended for repelling, destroying or controlling any pest, or regulating plant growth."@en ;
