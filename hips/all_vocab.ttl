ex:coastal_flooding a skos:Concept ;
    skos:prefLabel "Coastal Flooding"@en ;
    skos:definition "Coastal flooding occurs from multiple sources, including storm surges, waves and swell, seiches, riverine and flash floods near the coast, tides, sea-level rise and tsunamis. It is most frequently the result of storm surges and high winds coinciding with high tides. The surge itself is the result of the raising of sea levels due to low atmospheric pressure. In particular configurations, such as major estuaries or confined sea areas, the piling up of water is amplified by a combination of the shallowing of the seabed and retarding of return flow (WMO, 2011; WMO, 2022)."@en ;
    skos:prefLabel "Inondation côtière"@fr ;
    skos:prefLabel "Inundación costera"@es ;
    skos:prefLabel "Inondazione costiera"@it ;
    skos:prefLabel "Прибережне затоплення"@ua ;
    skos:prefLabel "Прибрежное затопление"@ru ;
    skos:prefLabel "海岸洪涝"@ch ;
    skos:prefLabel "Kustoverstroming"@nl .

ex:paratyphoid_fever a skos:Concept ;
    skos:prefLabel "Paratyphoid fever"@en ;
    skos:definition "Paratyphoid fever results from systemic infection with Salmonella enterica serotype Paratyphi. It is characterised by febrile illness and, in severe cases, gastrointestinal bleeding, altered mental status, intestinal perforation, and death (IHME 2021)."@en ;
