    skos:prefLabel "паратифоидная лихорадка"@ru ;
    skos:prefLabel "副伤寒"@ch .

ex:mercury a skos:Concept ;
    skos:prefLabel "Mercury"@en ;
    skos:definition "Mercury is a naturally occurring element that is found in air, water and soil. Exposure to mercury – even small amounts – may cause serious health problems and is a threat to the development of the foetus in utero and for children early in life (WHO, 2021)."@en ;
