    skos:prefLabel "生物多样性丧失"@ch ;
    skos:prefLabel "verlies van biodiversiteit"@nl .

ex:hepatitis_c a skos:Concept ;
    skos:prefLabel "Hepatitis C"@en ;
    skos:definition "Hepatitis C is a blood-borne liver disease caused by the hepatitis C virus: the virus can cause both acute and chronic hepatitis, ranging in severity from a mild illness lasting a few weeks to a serious, lifelong illness including liver cirrhosis and liver cancer. Hepatitis C is endemic and epidemic worldwide (WHO, 2024a)."@en ;
    skos:prefLabel "Hépatite C"@fr ;
