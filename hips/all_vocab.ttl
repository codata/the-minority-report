ex:pandemic_influenza_human a skos:Concept ;
    skos:prefLabel "Pandemic Influenza (Human)"@en ;
    skos:definition "Pandemic influenza is the worldwide spread of a new influenza virus to which there is little or no pre-existing immunity in the human population (WHO, 2019)."@en ;
    skos:prefLabel "Grippe pandémique"@fr ;
