    skos:prefLabel "食源性疾病"@ch ;
    skos:prefLabel "Voedselgerelateerde ziekten"@nl .

ex:cadmium a skos:Concept ;
    skos:prefLabel "Cadmium"@en ;
    skos:definition "Cadmium is a toxic heavy metal which is widely distributed in the Earth’s crust (soil and rocks), air and water; however, human activity has greatly increased levels in environmental media relevant to population exposure. Human exposure to cadmium represents a major public health concern as it has been associated with a range of acute and long-term adverse health effects and diseases (WHO, 2019)."@en ;
    skos:prefLabel "cadmium"@fr ;
    skos:prefLabel "cadmio"@es ;
    skos:prefLabel "cadmio"@it ;
    skos:prefLabel "Кадмій"@ua ;
    skos:prefLabel "кадмий"@ru ;
    skos:prefLabel "镉"@ch ;
    skos:prefLabel "cadmium"@nl .

ex:maritime_accident a skos:Concept ;
    skos:prefLabel "Maritime Accident"@en ;
    skos:definition "A maritime accident is an event, or a sequence of events, that has resulted in any of the following occurring directly in connection with the normal operation of a marine vessel: the death of, or serious injury to, a person; the loss of a person from a ship; the loss, presumed loss or abandonment of a marine vessel; material damage to a marine vessel; the stranding or disabling of a marine vessel, or the involvement of a marine vessel in a collision; material damage to the marine infrastructures external to a vessel, that could seriously endanger the safety of the vessel or another vessel or an individual; and severe damage to the environment, or the potential for severe damage to the environment, brought about by the damage of a marine vessel (United Nations, European Union and the International Transport Forum at the OECD, 2019)."@en ;
    skos:prefLabel "accident maritime"@fr ;
    skos:prefLabel "accidente marítimo"@es ;
    skos:prefLabel "incidente marittimo"@it ;
    skos:prefLabel "морська аварія"@ua ;
    skos:prefLabel "морская авария"@ru ;
    skos:prefLabel "海事事故"@ch ;
    skos:prefLabel "maritieme ongevallen"@nl .

ex:methanol a skos:Concept ;
    skos:prefLabel "Methanol"@en ;
    skos:definition "Methanol is a colourless, volatile liquid. Categorized as an alcohol, methanol is commonly used as a solvent and reagent in an array of industrial applications. Outbreaks of methanol poisoning most commonly arise from the consumption of adulterated or informally produced spirit drinks (adapted from NCBI, 2024 and WHO, 2014)."@en ;
    skos:prefLabel "méthanol"@fr ;
    skos:prefLabel "metanol"@es ;
    skos:prefLabel "metanolo"@it ;
    skos:prefLabel "метанол"@ua ;
    skos:prefLabel "метанол"@ru ;
    skos:prefLabel "甲醇"@ch ;
    skos:prefLabel "methanol"@nl .

ex:storm_surge a skos:Concept ;
    skos:prefLabel "Storm Surge"@en ;
    skos:definition "A storm surge reflects the difference between the actual water level under the influence of a meteorological disturbance (storm tide) and the level which would have occurred in the absence of the meteorological disturbance (i.e., astronomical tide) (WMO, 2008, 2011, 2017)."@en ;
    skos:prefLabel "marée de tempête"@fr ;
    skos:prefLabel "marea de tormenta"@es ;
    skos:prefLabel "onda di tempesta"@it ;
    skos:prefLabel "штормовий підйом"@ua ;
    skos:prefLabel "stormstijg"@nl .

ex:denial_of_service a skos:Concept ;
    skos:prefLabel "Denial of Service"@en ;
    skos:definition "Denial of service is the prevention of authorised access to resources or the delaying of time-critical operations. (Time-critical may be milliseconds or it may be hours, depending upon the service provided) (NIST, 2017)."@en ;
    skos:prefLabel "déni de service"@fr ;
    skos:prefLabel "denegación de servicio"@es ;
    skos:prefLabel "negazione di servizio"@it ;
    skos:prefLabel "Відмова в обслуговуванні"@ua ;
    skos:prefLabel "отказ в обслуживании"@ru ;
    skos:prefLabel "拒绝服务"@ch ;
    skos:prefLabel "Denial of Service"@nl .

ex:freezing_rain_ice_storm a skos:Concept ;
    skos:prefLabel "Freezing Rain (Ice storm)"@en ;
    skos:definition "Freezing rain is rain where the temperature of the water droplets is below 0°C. Drops of supercooled rain may freeze on impact with the ground, in-flight aircraft or other objects (WMO, 2017)."@en ;
    skos:prefLabel "pluie verglaçante"@fr ;
    skos:prefLabel "lluvia helada"@es ;
    skos:prefLabel "pioggia gelata"@it ;
    skos:prefLabel "замерзший дождь"@ru ;
    skos:prefLabel "冻雨"@ch ;
    skos:prefLabel "ijzel"@nl .

ex:ocean_acidification a skos:Concept ;
    skos:prefLabel "Ocean Acidification"@en ;
    skos:definition "Ocean acidification refers to a reduction in the pH of the ocean over an extended period, caused primarily by the uptake of carbon dioxide from the atmosphere. It can also result from other chemical additions to or subtractions from the ocean (IPCC, 2011)."@en ;
    skos:prefLabel "acidification des océans"@fr ;
    skos:prefLabel "acidificación oceánica"@es ;
    skos:prefLabel "acidificazione degli oceani"@it ;
    skos:prefLabel "Підкислення океану"@ua ;
    skos:prefLabel "Закисление океана"@ru ;
    skos:prefLabel "海洋酸化"@ch ;
    skos:prefLabel "Zee-acidificatie"@nl .

ex:chlorine a skos:Concept ;
    skos:prefLabel "Chlorine"@en ;
    skos:definition "Chlorine is a reactive pale green gas with many uses including disinfection of water. Chlorine is approximately 2.4 times heavier than air and has a characteristic odour similar to bleach. Most significant exposures to chlorine result from loss of containment of chlorine during storage and transport. Human exposure can result in symptoms ranging from mild irritation to rapid death related to pulmonary oedema. It is considered a significant public health hazard (adapted from IPCS, 1982 and PHE, 2019)."@en ;
    skos:prefLabel "chlore"@fr ;
    skos:prefLabel "cloro"@es ;
    skos:prefLabel "cloro"@it ;
    skos:prefLabel "хлор"@ua ;
    skos:prefLabel "хлор"@ru ;
    skos:prefLabel "氯"@ch ;
    skos:prefLabel "chloor"@nl .

ex:fog a skos:Concept ;
    skos:prefLabel "Fog"@en ;
    skos:definition "Fog is a suspension of very small, usually microscopic water droplets in the air, reducing visibility at the Earth’s surface (WMO, 2017)."@en ;
    skos:prefLabel "brouillard"@fr ;
    skos:prefLabel "niebla"@es ;
    skos:prefLabel "nebbia"@it ;
    skos:prefLabel "туман"@ua ;
    skos:prefLabel "туман"@ru ;
    skos:prefLabel "雾"@ch ;
    skos:prefLabel "mist"@nl .

ex:squall a skos:Concept ;
    skos:prefLabel "Squall"@en ;
    skos:definition "A squall is an atmospheric phenomenon characterised by a very large variation of wind speed: it begins suddenly, has a duration of the order of minutes and decreases suddenly in speed. It is often accompanied by a shower or thunderstorm (WMO, 2018)."@en ;
    skos:prefLabel "rafale"@fr ;
    skos:prefLabel "ráfaga"@es ;
    skos:prefLabel "Raffica"@it ;
    skos:prefLabel "шквальний вітер"@ua ;
    skos:prefLabel "шквал"@ru ;
    skos:prefLabel "阵风"@ch ;
    skos:prefLabel "windvlaag"@nl .

ex:soil_erosion a skos:Concept ;
    skos:prefLabel "Soil Erosion"@en ;
    skos:definition "Erosion is the wearing away of the land surface by water, wind, ice, gravity or other natural or anthropogenic agents that abrade, detach and remove soil particles from one point on the earth's surface, for deposition elsewhere. Four main forms are recognized: water, wind, harvest and tillage. (FAO, 2020)."@en ;
    skos:prefLabel "érosion des sols"@fr ;
    skos:prefLabel "erosión del suelo"@es ;
    skos:prefLabel "erosione del suolo"@it ;
    skos:prefLabel "ерозія ґрунту"@ua ;
    skos:prefLabel "эрозия почвы"@ru ;
    skos:prefLabel "土壤侵蚀"@ch ;
    skos:prefLabel "bodemerosie"@nl .

ex:subsidence_and_uplift a skos:Concept ;
    skos:prefLabel "Subsidence and Uplift"@en ;
    skos:definition "Subsidence is a lowering or collapse of the ground (BGS, 2020). Uplift is the converse."@en ;
    skos:prefLabel "affaissement et soulèvement"@fr ;
    skos:prefLabel "subsidencia y levantamiento"@es ;
    skos:prefLabel "subsidenza e sollevamento"@it ;
    skos:prefLabel "осідання та підняття"@ua ;
    skos:prefLabel "оседание и поднятие"@ru ;
    skos:prefLabel "沉降和隆起"@ch .

ex:sexually_transmitted_infections a skos:Concept ;
    skos:prefLabel "Sexually Transmitted Infections"@en ;
    skos:definition "Sexually transmitted infections are transmitted through sexual contact, including vaginal, anal and oral sex and some can also be transmitted from mother-to-child during pregnancy, childbirth and breastfeeding (WHO, 2024)."@en ;
    skos:prefLabel "Infections sexuellement transmissibles"@fr ;
    skos:prefLabel "Infecciones de transmisión sexual"@es ;
    skos:prefLabel "Infezioni sessualmente trasmissibili"@it ;
    skos:prefLabel "Інфекції, що передаються статевим шляхом"@ua ;
    skos:prefLabel "Инфекции, передающиеся половым путем"@ru ;
    skos:prefLabel "性传播疾病"@ch ;
    skos:prefLabel "sexueel overdraagbare infecties"@nl .

ex:new_world_screwworm_nws a skos:Concept ;
    skos:prefLabel "New World Screwworm (NWS)"@en ;
    skos:definition "The New World screwworm (NWS),Cochliomyia hominivorax(Coquerel), is an obligate parasite of mammals, including humans, during their larval stages. Larvae feeding on the skin and underlying tissues of the host cause a condition known as wound or traumatic myiasis, which can be fatal (adapted from PAHO, no date and WOAH, no date)."@en ;
    skos:prefLabel "Screwworm du Nouveau Monde"@fr ;
    skos:prefLabel "Screwworm del Nuovo Mondo"@it ;
    skos:prefLabel "新世界螺旋虫"@ch ;
    skos:prefLabel "Nieuwe Wereld schroefworm"@nl .

ex:road_traffic_accident a skos:Concept ;
    skos:prefLabel "Road Traffic Accident"@en ;
    skos:definition "A road traffic accident involving at least one road vehicle in motion on a public road or private road to which the public has right of access, resulting in at least one injured or killed person. Approximately 1.19 million people die each year as a result of road traffic crashes, which are the leading cause of death for children and young adults aged 5-29 years with 92% of the world's fatalities on the roads occurring in low- and middle-income countries, even though these countries have around 60% of the world's vehicles (adapted from UNECE, Eurostat, ITF, 2019 and WHO, 2023a)."@en ;
    skos:prefLabel "Accident de la circulation routière"@fr ;
    skos:prefLabel "accidente de tráfico"@es ;
    skos:prefLabel "incidente di traffico stradale"@it ;
    skos:prefLabel "дорожньо-транспортна пригода"@ua ;
    skos:prefLabel "дорожно-транспортное происшествие"@ru ;
    skos:prefLabel "道路交通事故"@ch ;
    skos:prefLabel "verkeersongeval"@nl .

ex:coastal_erosion_and_accretion a skos:Concept ;
    skos:prefLabel "Coastal Erosion and Accretion"@en ;
    skos:definition "Coastal erosion is the process of removal of material at the shoreline which leads to the loss of land as the shoreline retreats landward.  Coastal accretion is the product of deposition of material at the shoreline which leads to gain of land as the coast advances seaward (Gibb, 1978)."@en ;
    skos:prefLabel "Érosion et Accrétion côtières"@fr ;
    skos:prefLabel "Erosión y Acreción costeras"@es ;
    skos:prefLabel "Erosione e accrezione costiera"@it ;
    skos:prefLabel "Прибережна ерозія та акреція"@ua ;
    skos:prefLabel "海岸侵蚀与沉积"@ch ;
    skos:prefLabel "kusterosie en accretie"@nl .

ex:levels_of_contaminants_in_food_and_feed a skos:Concept ;
    skos:prefLabel "Levels of Contaminants in Food and Feed"@en ;
    skos:definition "A contaminant in food and feed is defined as any substance not intentionally added but present in such food or feed as a result of the production, manufacture, processing, preparation, treatment, packing, packaging, transport or storage, or as a result of environmental contamination, which can lead to major public hazards (FAO and WHO, 2019)."@en ;
    skos:prefLabel "Niveaux de contaminants dans les aliments et les aliments pour animaux"@fr ;
    skos:prefLabel "Niveles de contaminantes en alimentos y piensos"@es ;
    skos:prefLabel "Livelli di contaminanti negli alimenti e nei mangimi"@it ;
    skos:prefLabel "Рівні забруднюючих речовин у харчових продуктах і кормах"@ua ;
    skos:prefLabel "Уровни загрязнителей в пищевых продуктах и корме"@ru ;
    skos:prefLabel "食品和饲料中的污染物水平"@ch ;
    skos:prefLabel "Niveaus van verontreinigende stoffen in voedsel en veevoeder"@nl .

ex:seiche a skos:Concept ;
    skos:prefLabel "Seiche"@en ;
    skos:definition "Seiches are sea-level oscillations at the resonant frequency of enclosed bodies of water (WMO, 2011)."@en ;
    skos:prefLabel "seiche"@fr ;
    skos:prefLabel "seiche"@es ;
    skos:prefLabel "seiche"@it ;
    skos:prefLabel "сейш"@ua ;
    skos:prefLabel "сейш"@ru ;
    skos:prefLabel "seiche"@nl .

ex:critical_infrastructure_failure a skos:Concept ;
    skos:prefLabel "Critical Infrastructure Failure"@en ;
    skos:definition "Critical Infrastructure failure is defined as the failure in one or more of the physical structures, facilities, networks and other assets which provide services that are essential to the social and economic functioning of a community or society (UNGA, 2016)."@en ;
    skos:prefLabel "guasto delle infrastrutture critiche"@it ;
    skos:prefLabel "збої критичної інфраструктури"@ua ;
    skos:prefLabel "Сбои критической инфраструктуры"@ru ;
    skos:prefLabel "关键基础设施故障"@ch ;
    skos:prefLabel "falen van kritieke infrastructuur"@nl .

