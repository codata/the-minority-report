    skos:prefLabel "Elektrisch en elektronisch afval"@nl .

ex:liquefaction a skos:Concept ;
    skos:prefLabel "Liquefaction"@en ;
    skos:definition "Liquefaction refers to the loss of strength experienced in loosely packed, saturated or close to saturated sediments at or near the ground surface in response to strong ground shaking, such as earthquakes, cyclic loading (repeated application of stresses), and vibration from machinery, or due to the development of excess pore water pressure resulting from a change in head or confining pressures. (c. AGI, 2017; USGS, no date)."@en ;
    skos:prefLabel "Liquéfaction"@fr ;
    skos:prefLabel "Liquefacción"@es ;
    skos:prefLabel "liquefazione"@it ;
    skos:prefLabel "ливідізація"@ru ;
    skos:prefLabel "液化"@ch ;
    skos:prefLabel "liquefactie"@nl .

ex:brucellosis a skos:Concept ;
    skos:prefLabel "Brucellosis"@en ;
    skos:definition "Brucellosis is a bacterial disease caused by various Brucella species, which mainly infect cattle, swine, goats, sheep and dogs. Humans generally acquire the disease through direct contact with infected animals (WHO, 2020)."@en ;
    skos:prefLabel "brucellose"@fr ;
    skos:prefLabel "brucelosis"@es ;
    skos:prefLabel "brucellosi"@it ;
    skos:prefLabel "бруцельоз"@ua ;
