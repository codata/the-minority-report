ex:permafrost_loss a skos:Concept ;
    skos:prefLabel "Permafrost Loss"@en ;
    skos:definition "Permafrost is defined as ground that remains frozen at or below 0°C for a minimum of two consecutive years. Permafrost loss, also known as permafrost thaw, is the progressive loss of ground ice in permafrost, usually due to input of heat. Thaw can occur over decades to centuries over the entire depth of permafrost ground, with impacts occurring while thaw progresses. During thaw, temperature fluctuations are subdued because energy is transferred by phase change between ice and water. After the transition from permafrost to non-permafrost, ground can be described as thawed (IPCC, 2019)."@en ;
    skos:prefLabel "perte de pergélisol"@fr ;
    skos:prefLabel "perdita di permafrost"@it ;
    skos:prefLabel "Відтавання вічної мерзлоти"@ua ;
    skos:prefLabel "Таяние вечной мерзлоты"@ru ;
    skos:prefLabel "永久冻土融化"@ch ;
    skos:prefLabel "permafrostverlies"@nl .

ex:safety_hazards_associated_with_oil_and_gas a skos:Concept ;
    skos:prefLabel "Safety Hazards Associated with Oil and Gas"@en ;
    skos:definition "Oil and gas extraction, and associated servicing activities involve many types of equipment and materials. Identifying and controlling hazards is critical to preventing injuries and deaths (US Department of Labor, no date)."@en ;
    skos:prefLabel "Risques de sécurité liés au pétrole et au gaz"@fr ;
    skos:prefLabel "Riesgos de seguridad asociados con el petróleo y el gas"@es ;
    skos:prefLabel "Rischi di sicurezza associati al petrolio e al gas"@it ;
    skos:prefLabel "石油和天然气相关的安全危害"@ch ;
    skos:prefLabel "Veiligheidsrisico's verbonden aan olie en gas"@nl .

ex:supply_chain_attack a skos:Concept ;
    skos:prefLabel "Supply Chain Attack"@en ;
    skos:definition "A supply chain attack is when products, services, or technology you are supplied with have been breached or compromised, and are in turn used to infiltrate and further compromise your own systems (ICO, no date)."@en ;
