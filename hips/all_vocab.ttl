ex:anthrax a skos:Concept ;
    skos:prefLabel "Anthrax"@en ;
    skos:definition "Anthrax is a disease caused by the spore-forming bacteria Bacillus anthracis. Anthrax is primarily a disease of herbivorous animals, although all mammals, including humans, can contract it. In humans, anthrax manifests itself in three distinct patterns (cutaneous, gastrointestinal, inhalational) (adapted from WHO, FAO, & OIE, 2008; CDC, 2020)."@en ;
    skos:prefLabel "anthrax"@fr ;
    skos:prefLabel "ántrax"@es ;
    skos:prefLabel "антраx"@ru ;
    skos:prefLabel "炭疽病"@ch ;
    skos:prefLabel "anthrax"@nl .

ex:shigellosis a skos:Concept ;
    skos:prefLabel "Shigellosis"@en ;
    skos:definition "Shigellosis is an acute invasive enteric infection caused by bacteria belonging to the genus Shigella and is estimated to cause at least 80 million cases of bloody diarrhoea and 700,000 deaths each year (WHO, 2005)."@en ;
    skos:prefLabel "shigellose"@fr ;
    skos:prefLabel "shigelosis"@es ;
    skos:prefLabel "shigellosi"@it ;
    skos:prefLabel "шигеллоз"@ua ;
    skos:prefLabel "шигеллез"@ru ;
    skos:prefLabel "志贺菌病"@ch ;
    skos:prefLabel "shigellose"@nl .

ex:cholera a skos:Concept ;
    skos:prefLabel "Cholera"@en ;
    skos:definition "Cholera is an acute diarrhoeal infection caused by ingestion of food or water contaminated with the bacterium Vibrio cholerae. Cholera is a global threat to public health (WHO, 2024a)."@en ;
    skos:prefLabel "Choléra"@fr ;
    skos:prefLabel "Cólera"@es ;
    skos:prefLabel "Colera"@it ;
    skos:prefLabel "Холера"@ua ;
    skos:prefLabel "Холера"@ru ;
    skos:prefLabel "霍乱"@ch ;
    skos:prefLabel "Cholera"@nl .

ex:sand_haze a skos:Concept ;
    skos:prefLabel "Sand haze"@en ;
    skos:definition "A dust haze (or sand haze) is a suspension in the air of dust or small sand particles, raised from the ground prior to the time of observation by a dust storm or sandstorm. The dust storm or sandstorm may have occurred either at or near the observation site or far from it (WMO, 2025)."@en ;
    skos:prefLabel "brume de sable"@fr ;
    skos:prefLabel "calima"@es ;
    skos:prefLabel "nebbia di sabbia"@it ;
    skos:prefLabel "Пиловий туман"@ua ;
    skos:prefLabel "песчаная дымка"@ru ;
    skos:prefLabel "沙尘雾"@ch ;
    skos:prefLabel "zandnevel"@nl .

ex:ammonium_nitrate a skos:Concept ;
    skos:prefLabel "Ammonium Nitr​​ate"@en ;
    skos:definition "Ammonium nitrate (NH4NO3) is principally used as a high nitrogen content fertilizer in agricultural applications. It is also a major component of industrial explosives, and similar mixtures have been used as improvised explosive devices. Thousands of people have been killed in accidental ammonium nitrate explosions triggered either by a shock/explosion, or by fire spreading into a storage facility. Overuse as a fertilizer can lead to contamination of drinking water."@en ;
    skos:prefLabel "nitrate d'ammonium"@fr ;
    skos:prefLabel "nitrato de amonio"@es ;
    skos:prefLabel "nitrato di ammonio"@it ;
    skos:prefLabel "硝酸铵"@ch ;
    skos:prefLabel "ammoniumnitraat"@nl .

ex:meningococcal_meningitis a skos:Concept ;
    skos:prefLabel "Meningococcal Meningitis"@en ;
    skos:definition "Meningococcal meningitis is a bacterial form of meningitis, a serious infection of the thin lining that surrounds the brain and spinal cord, that is caused by the bacteriumNeisseria meningitidis. Meningococcal meningitis has the potential to cause large-scale epidemics and is observed worldwide (adapted from WHO, 2025)."@en ;
    skos:prefLabel "méningite méningococcique"@fr ;
    skos:prefLabel "meningitis meningocócica"@es ;
    skos:prefLabel "meningite meningococcica"@it ;
    skos:prefLabel "менінгококовий менінгіт"@ua ;
    skos:prefLabel "менингококковый менингит"@ru ;
    skos:prefLabel "脑膜炎球菌性脑膜炎"@ch ;
    skos:prefLabel "meningokokale meningitis"@nl .

ex:cold_wave a skos:Concept ;
    skos:prefLabel "Cold Wave"@en ;
    skos:definition "A cold wave is a period of marked and unusual cold weather characterised by a sharp and significant drop in air temperatures near the surface (maximum, minimum and daily average) over a large area and persisting below certain thresholds for at least two consecutive days during the cold season (WMO, 2020)."@en ;
    skos:prefLabel "vague de froid"@fr ;
    skos:prefLabel "ola de frío"@es ;
    skos:prefLabel "ondata di freddo"@it ;
    skos:prefLabel "холодна хвиля"@ua ;
    skos:prefLabel "холодная волна"@ru ;
    skos:prefLabel "寒潮"@ch ;
    skos:prefLabel "koude golf"@nl .

ex:geomagnetic_disturbance a skos:Concept ;
    skos:prefLabel "Geomagnetic Disturbance"@en ;
    skos:definition "A geomagnetic disturbance refers to perturbations in Earth's magnetosphere caused by sudden and significant variations in the solar wind's speed, density, and magnetic properties. The intensity of a geomagnetic disturbance can be measured using different geomagnetic indexes. Although a geomagnetic disturbance is a global phenomenon, the intensities and characteristics vary at different geographic locations (NOAA, 2023)."@en ;
    skos:prefLabel "perturbation géomagnétique"@fr ;
    skos:prefLabel "perturbación geomagnética"@es ;
    skos:prefLabel "disturbo geomagnetico"@it ;
    skos:prefLabel "геомагнітне порушення"@ua ;
    skos:prefLabel "геомагнитное возмущение"@ru ;
    skos:prefLabel "地磁扰动"@ch ;
    skos:prefLabel "geomagnetische verstoring"@nl .

ex:insect_pest_infestations a skos:Concept ;
    skos:prefLabel "Insect Pest Infestations"@en ;
    skos:definition "An insect pest infestation is a recently detected insect pest population, including an incursion, or a sudden significant increase of an established insect in an area leading to damage to plants in production fields, forests or natural habitats and causing substantial damage to productivity, biodiversity or natural resources (adapted from IPPC Secretariat, 2024)."@en ;
    skos:prefLabel "Infestation d'insectes nuisibles"@fr ;
    skos:prefLabel "Infestación de plagas de insectos"@es ;
    skos:prefLabel "infestazioni di insetti pestiferi"@it ;
    skos:prefLabel "інфестація шкідливих комах"@ua ;
    skos:prefLabel "昆虫害虫爆发"@ch ;
    skos:prefLabel "Insectenplagen"@nl .

ex:soil_degradation a skos:Concept ;
    skos:prefLabel "Soil Degradation"@en ;
    skos:definition "Soil degradation is defined as a change in soil health status resulting in a diminished capacity of the ecosystem to provide goods and services for its beneficiaries (FAO, 2020)."@en ;
    skos:prefLabel "dégradation des sols"@fr ;
    skos:prefLabel "degradación del suelo"@es ;
    skos:prefLabel "Degrado del suolo"@it ;
    skos:prefLabel "деградація ґрунтів"@ua ;
    skos:prefLabel "деградация почвы"@ru ;
    skos:prefLabel "土壤退化"@ch ;
    skos:prefLabel "bodemdegradatie"@nl .

ex:surface_water_flooding a skos:Concept ;
    skos:prefLabel "Surface Water Flooding"@en ;
    skos:definition "Surface water flooding is that part of the rain which remains on the ground surface during rain and either runs off or infiltrates after the rain ends, not including depression storage (WMO, 2012)."@en ;
    skos:prefLabel "Inundación de agua superficial"@es ;
    skos:prefLabel "Inondazione da ruscellamento superficiale"@it ;
    skos:prefLabel "поверхневий паводок"@ua ;
    skos:prefLabel "Поверхностное наводнение"@ru ;
    skos:prefLabel "地表水洪水"@ch ;
    skos:prefLabel "Oppervlaktewateroverstroming"@nl .

ex:lassa_fever a skos:Concept ;
    skos:prefLabel "Lassa Fever"@en ;
    skos:definition "Lassa fever is a zoonotic disease associated with acute and potentially fatal haemorrhagic illness caused by Lassa virus. The virus is a single-stranded RNA virus belonging to the virus family Arenaviridae. About 1 in 5 infections result in severe disease, where the virus affects several organs such as the liver, spleen and kidneys. (WHO, 2024a)."@en ;
    skos:prefLabel "Fièvre de Lassa"@fr ;
    skos:prefLabel "Fiebre de Lassa"@es ;
    skos:prefLabel "Febbre di Lassa"@it ;
    skos:prefLabel "Ласса‑вірусна лихоманка"@ua ;
    skos:prefLabel "Лихорадка Ласса"@ru ;
    skos:prefLabel "拉萨热"@ch .

ex:corrosive_substances a skos:Concept ;
    skos:prefLabel "Corrosive Substances"@en ;
    skos:definition "Corrosive substances are materials, such as strong acids and strong bases, that, through chemical reactions, cause visible destruction of biological tissues, and other materials. Acids are substances that have a high tendency to donate protons when completely dissociating into ions in water; whereas strong bases are substances that accept protons when completely dissociating into ions in water. Both are highly corrosive and catalyse the decomposition of biological molecules. (Burrows et al., 2021)"@en ;
    skos:prefLabel "Substances corrosives"@fr ;
    skos:prefLabel "Sustancias corrosivas"@es ;
    skos:prefLabel "Sostanze corrosive"@it ;
    skos:prefLabel "Корозійні речовини"@ua ;
    skos:prefLabel "Коррозионные вещества"@ru ;
    skos:prefLabel "腐蚀性物质"@ch ;
    skos:prefLabel "Corrosieve stoffen"@nl .

ex:natech a skos:Concept ;
    skos:prefLabel "Natech"@en ;
    skos:definition "Natural hazard triggered technological accident (Showalter et al., 1994)."@en ;
    skos:prefLabel "NAtech"@fr ;
    skos:prefLabel "NAtech"@es ;
    skos:prefLabel "NAtech"@it ;
    skos:prefLabel "НАТех"@ru ;
    skos:prefLabel "NAtech"@ch ;
    skos:prefLabel "NAtech"@nl .

ex:tsunami a skos:Concept ;
    skos:prefLabel "Tsunami"@en ;
    skos:definition "Tsunami, a Japanese term meaning 'wave' (‘nami’) in a harbour (‘tsu’), refers to a series of long-period travelling waves, typically caused by disturbances such as earthquakes occurring beneath or near the ocean floor (IOC, 2019)."@en ;
    skos:prefLabel "tsunami"@fr ;
    skos:prefLabel "tsunami"@es ;
    skos:prefLabel "tsunami"@it ;
    skos:prefLabel "цунамі"@ua ;
    skos:prefLabel "цунами"@ru ;
    skos:prefLabel "海啸"@ch ;
    skos:prefLabel "tsunami"@nl .

ex:leaks_and_spills a skos:Concept ;
    skos:prefLabel "Leaks and Spills"@en ;
    skos:definition "A leak or a spill is an incident involving the uncontrolled release of a toxic substance, potentially resulting in harm to public health and the environment. Chemical incidents can occur as a result of natural events, or as a result of accidental or intentional events. These incidents can be sudden and acute or have a slow onset when there is a ‘silent’ release of a chemical. Leaks and spills can range from small releases to full-scale major emergencies (adapted from WHO, no date)."@en ;
    skos:prefLabel "fuites et déversements"@fr ;
    skos:prefLabel "fugas y derrames"@es ;
    skos:prefLabel "утечі та розлили"@ua ;
    skos:prefLabel "утечки и разливы"@ru ;
    skos:prefLabel "泄漏与溢出"@ch ;
    skos:prefLabel "Lekken en morsen"@nl .

ex:volcanic_gases_and_aerosols a skos:Concept ;
    skos:prefLabel "Volcanic Gases and Aerosols"@en ;
    skos:definition "Volcanic gas includes any gas-phase substance that is emitted by volcanic or volcanic-geothermal activity. Volcanic aerosols include liquid or solid particles that are small enough to be suspended in the air, and that are emitted by volcanic or volcanic-geothermal activity (adapted from Baxter and Horwell, 2015, Fischer and Chiodini, 2015, and Williams-Jones and Rymer ,2015)."@en ;
    skos:prefLabel "Gaz volcaniques et aérosols volcaniques"@fr ;
    skos:prefLabel "gases volcánicos y aerosoles"@es ;
    skos:prefLabel "Gas vulcanici e aerosol vulcanici"@it ;
    skos:prefLabel "вулканічні гази та аерозолі"@ua ;
    skos:prefLabel "вулканические газы и аэрозоли"@ru ;
    skos:prefLabel "火山气体和气溶胶"@ch ;
    skos:prefLabel "Vulkanische gassen en aerosolen"@nl .

ex:land_degradation a skos:Concept ;
    skos:prefLabel "Land Degradation"@en ;
    skos:definition "Land degradation is the reduction or loss, in arid, semi-arid and dry sub-humid areas, of the biological or economic productivity and complexity of rainfed cropland, irrigated cropland or range, pasture, forest and woodlands resulting from land uses or from a process or combination of processes, including processes arising from human activities and habitation patterns such as soil erosion caused by wind and/or water; deterioration of the physical, chemical and biological or economic properties of soil; and long-term loss of natural vegetation (UNCCD, 1993)."@en ;
    skos:prefLabel "Dégradation des terres"@fr ;
    skos:prefLabel "degradación de la tierra"@es ;
    skos:prefLabel "degrado del suolo"@it ;
    skos:prefLabel "деградація земель"@ua ;
    skos:prefLabel "деградация земель"@ru ;
    skos:prefLabel "土地退化"@ch ;
    skos:prefLabel "landdegradatie"@nl .

ex:listeriosis a skos:Concept ;
    skos:prefLabel "Listeriosis"@en ;
    skos:definition "Listeriosis is a foodborne infection caused by the bacteriumListeria monocytogeneswhich can be invasive (the more serious form of the disease) or non-invasive (the milder form of the disease). Listeriosis outbreaks occur in all countries and can be a significant public health concern (WHO, 2018)."@en ;
    skos:prefLabel "Listeriose"@fr ;
    skos:prefLabel "Listeriosis"@es ;
    skos:prefLabel "Listeriosi"@it ;
    skos:prefLabel "лістеріоз"@ua ;
    skos:prefLabel "Листериоз"@ru ;
    skos:prefLabel "李斯特菌病"@ch ;
    skos:prefLabel "Listeriose"@nl .

ex:locust_upsurge a skos:Concept ;
    skos:prefLabel "Locust upsurge"@en ;
    skos:definition "Widespread and heavy infestations of crops and natural vegetation by locusts causing significant threats to food security, livelihoods and natural habitats in multiple regions (adapted from FAO, 2009a)."@en ;
    skos:prefLabel "plaga de langostas"@es ;
    skos:prefLabel "Surto di locuste"@it ;
    skos:prefLabel "спалах сарани"@ua ;
