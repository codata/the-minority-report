    skos:prefLabel "放射性物质与材料"@ch .

ex:waterborne_diseases a skos:Concept ;
    skos:prefLabel "Waterborne Diseases"@en ;
    skos:definition "Contaminated water and poor sanitation are linked to transmission of diseases such as cholera, diarrhoea, dysentery, hepatitis A, hepatitis E, typhoid and polio (adapted from WHO, 2023a and WHO, 2023b)."@en ;
    skos:prefLabel "Maladies d'origine hydrique"@fr ;
    skos:prefLabel "Enfermedades transmitidas por el agua"@es ;
    skos:prefLabel "malattie trasmesse dall’acqua"@it ;
    skos:prefLabel "Інфекційні хвороби, що передаються водним шляхом"@ua ;
