ex:persistent_organic_pollutants a skos:Concept ;
    skos:prefLabel "Persistent Organic Pollutants"@en ;
    skos:definition "Persistent organic pollutants (POPs) are chemicals of global concern due to their potential for long-range transport, persistence in the environment, ability to bio-magnify and bio-accumulate in ecosystems, as well as their significant negative effects on human health and the environment."@en ;
