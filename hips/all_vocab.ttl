    skos:prefLabel "Afrikaanse varkenspest"@nl .

ex:hepatitis_b a skos:Concept ;
    skos:prefLabel "Hepatitis B"@en ;
    skos:definition "Hepatitis B is a vaccine-preventable disease, that is endemic and epidemic worldwide and is caused by the Hepatitis B virus (HBV). HBV can cause both acute and chronic liver disease. Chronic infection puts people at high risk of death from cirrhosis and liver cancer (WHO, 2024)."@en ;
