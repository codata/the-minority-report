    skos:prefLabel "Продвинутая постоянная угроза"@ru ;
    skos:prefLabel "高级持续性威胁"@ch ;
    skos:prefLabel "Geavanceerde Persistente Bedreiging"@nl .

ex:sub_tropical_cyclone a skos:Concept ;
    skos:prefLabel "Sub-Tropical Cyclone"@en ;
    skos:definition "A subtropical cyclone is a non-frontal, low-pressure system that has characteristics of both tropical and extra-tropical cyclones. Like tropical cyclones, they are non-frontal, synoptic-scale cyclones that originate over tropical or subtropical waters and have a closed surface wind circulation about a well-defined centre (WMO, 2024 a)."@en ;
    skos:prefLabel "cyclone subtropical"@fr ;
    skos:prefLabel "ciclón subtropical"@es ;
    skos:prefLabel "ciclone subtropicale"@it ;
    skos:prefLabel "субтропічний циклон"@ua ;
    skos:prefLabel "субтропический циклон"@ru ;
    skos:prefLabel "亚热带气旋"@ch ;
    skos:prefLabel "subtropische cycloon"@nl .

ex:hiv_and_aids a skos:Concept ;
    skos:prefLabel "HIV and AIDS"@en ;
    skos:definition "Human immunodeficiency virus (HIV) is a virus that attacks the body’s immune system. Acquired immunodeficiency syndrome (AIDS) occurs at the most advanced stage of infection. HIV targets the body’s white blood cells, weakening the immune system. This makes it easier to get sick with diseases like tuberculosis, infections and some cancers. HIV is spread from the body fluids of an infected person, including blood, breast milk, semen and vaginal fluids. WHO now defines Advanced HIV Disease (AHD) as CD4 cell count less than 200 cells/mm3 or WHO stage 3 or 4 in adults and adolescents. All children younger than 5 years of age living with HIV are considered to have advanced HIV disease (WHO, 2024a)."@en ;
    skos:prefLabel "VIH et SIDA"@fr ;
    skos:prefLabel "VIH y SIDA"@es ;
    skos:prefLabel "VIH e SIDA"@it ;
    skos:prefLabel "ВИЧ и СПИД"@ru ;
    skos:prefLabel "艾滋病毒和艾滋病"@ch ;
    skos:prefLabel "HIV en AIDS"@nl .

ex:lahars a skos:Concept ;
    skos:prefLabel "Lahars"@en ;
    skos:definition "Lahars are discrete, rapid, gravity-driven, water-saturated flows containing water and solid particles of volcanic rock, sediment, ice, wood, and other debris that originate at volcanoes (Gudmundsson, 2015; Vallance and Iverson, 2015)."@en ;
    skos:prefLabel "lahar"@fr ;
    skos:prefLabel "lahares"@es ;
    skos:prefLabel "lahar"@it ;
    skos:prefLabel "火山泥石流"@ch ;
    skos:prefLabel "lahar"@nl .

ex:substandard_and_falsified_medical_products a skos:Concept ;
    skos:prefLabel "Substandard and Falsified Medical Products"@en ;
    skos:definition "Substandard and falsified medical products are defined as those that may cause harm to patients and fail to treat the diseases for which they were intended (WHO, 2018)."@en ;
