ex:leprosy a skos:Concept ;
    skos:prefLabel "Leprosy"@en ;
    skos:definition "Leprosy is a curable infectious disease, endemic in many countries, caused by the bacteriumMycobacterium leprae(M. leprae). It mainly affects the skin, peripheral nerves, mucosa of the upper respiratory tract and eyes. Untreated, it can lead to permanent disability (adapted from WHO, 2025)."@en ;
