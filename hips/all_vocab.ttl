    skos:prefLabel "gebouweninstorting"@nl .

ex:invasive_species_including_weeds a skos:Concept ;
    skos:prefLabel "Invasive Species, Including Weeds"@en ;
    skos:definition "‘Invasive species’, also known as ‘alien invasive species’, are species whose introduction, establishment and spread into new areas threaten ecosystems, habitats or other species and cause social, economic or environmental harm, or harm to human health (FAO, 2007:82)."@en ;
    skos:prefLabel "Espèces envahissantes, y compris les mauvaises herbes"@fr ;
    skos:prefLabel "Especies invasoras, incluidas las malezas"@es ;
    skos:prefLabel "Specie invasive, incluse le erbe infestanti"@it ;
    skos:prefLabel "Інвазивні види"@ua ;
    skos:prefLabel "Инвазивные виды"@ru ;
    skos:prefLabel "入侵物种"@ch ;
    skos:prefLabel "Invasieve soorten"@nl .

ex:wetland_lossdegradation a skos:Concept ;
    skos:prefLabel "Wetland Loss/Degradation"@en ;
    skos:definition "Wetland loss/degradation is a negative trend in wetland condition, caused by physical or direct/indirect human-induced processes, expressed as a long-term reduction or loss of at least one of the following: biological productivity, ecological role or value to humans (Olsson et al., 2019). Wetlands are defined as areas of marsh, fen, peatland or water, whether natural or artificial, permanent or temporary, with water that is static or flowing, fresh, brackish or salt, including areas of marine water the depth of which at low tide does not exceed six metres (Convention on Wetlands, 1971: Article 1.1). Wetlands may incorporate riparian and coastal zones adjacent to the wetlands, and islands or bodies of marine water deeper than six metres at low tide lying within the wetlands (Convention on Wetlands, 1971: Article 2.1)."@en ;
    skos:prefLabel "Perte et dégradation des zones humides"@fr ;
    skos:prefLabel "Pérdida y degradación de humedales"@es ;
    skos:prefLabel "perdita o degradazione delle zone umide"@it ;
    skos:prefLabel "Втрата та деградація водно-болотних угідь"@ua ;
    skos:prefLabel "Потеря и деградация водно-болотных угодий"@ru ;
    skos:prefLabel "湿地损失或退化"@ch ;
    skos:prefLabel "Verlies en degradatie van wetlands"@nl .

ex:plague a skos:Concept ;
    skos:prefLabel "Plague"@en ;
    skos:definition "Plague is caused by the bacteriaYersinia pestis, and can be a very severe disease in people, with a case-fatality ratio of 30% to 60% for the bubonic type and is always fatal for the pneumonic kind when left untreated (WHO, 2022)."@en ;
    skos:prefLabel "peste"@fr ;
