    skos:prefLabel "轮状病毒"@ch ;
    skos:prefLabel "rotavirus"@nl .

ex:fire a skos:Concept ;
    skos:prefLabel "Fire"@en ;
    skos:definition "Fire-related technological incidents can be defined as accidental or intentional events that result in the actual or potential physical damage to property and exposure of responders and/or members of the public to a chemical hazard (adapted from WHO, no date)"@en ;
    skos:prefLabel "incendie"@fr ;
    skos:prefLabel "incendio"@es ;
    skos:prefLabel "incendio"@it ;
    skos:prefLabel "пожежа"@ua ;
