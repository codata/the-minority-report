ex:prion_diseases a skos:Concept ;
    skos:prefLabel "Prion Diseases"@en ;
    skos:definition "Prion diseases are a family of rare progressive neurodegenerative disorders that affect both humans and animals (Adapted from CDC, 2024, and WHO, no date)."@en ;
    skos:prefLabel "Maladies à prions"@fr ;
    skos:prefLabel "Enfermedades por priones"@es ;
