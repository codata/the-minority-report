    skos:prefLabel "Productos médicos subestándar y falsificados"@es ;
    skos:prefLabel "Ліки неналежної якості та підроблені"@ua ;
    skos:prefLabel "劣质和假冒医药产品"@ch ;
    skos:prefLabel "substandard en vervalste medische producten"@nl .

ex:derecho a skos:Concept ;
    skos:prefLabel "Derecho"@en ;
    skos:definition "Derechos are fast-moving bands of thunderstorms with destructive winds. The winds can be as strong as those found in hurricanes or even tornadoes. Unlike hurricanes and tornadoes, these winds follow straight lines (NOAA, 2019)."@en ;
    skos:prefLabel "derecho"@fr ;
    skos:prefLabel "derecho"@es ;
    skos:prefLabel "Derecho"@it ;
    skos:prefLabel "прямолінійний штормовий вітер"@ua ;
    skos:prefLabel "прямолинейный штормовой ветер"@ru ;
    skos:prefLabel "强直线风暴"@ch ;
    skos:prefLabel "Derecho"@nl .

ex:antimicrobial_resistance a skos:Concept ;
    skos:prefLabel "Antimicrobial Resistance"@en ;
    skos:definition "Antimicrobial-resistant (AMR) microorganisms are bacteria, fungi, viruses, or parasites that evolve to withstand antimicrobial treatments, including antibiotics, antifungals, antivirals, and antiparasitics. These resistant microorganisms, make infections harder to treat, increasing the risk of disease spread, severe illness, and mortality. AMR is a major global public health and food security challenge and is driven by the misuse and overuse of antimicrobials in human medicine, animal health, and plant production and protection, as well as environmental contamination (adapted from WHO, 2023 and FAO, 2025)."@en ;
    skos:prefLabel "Résistance aux antimicrobiens"@fr ;
    skos:prefLabel "Resistencia a los antimicrobianos"@es ;
    skos:prefLabel "Resistenza antimicrobica"@it ;
    skos:prefLabel "Антимікробна резистентність"@ua ;
    skos:prefLabel "Антимикробная резистентность"@ru ;
    skos:prefLabel "抗菌药物耐药性"@ch ;
    skos:prefLabel "Antimicrobiële resistentie"@nl .

ex:lumpy_skin_disease a skos:Concept ;
    skos:prefLabel "Lumpy Skin Disease"@en ;
    skos:definition "Lumpy skin disease is a vector-borne pox disease of domestic cattle and Asian water buffalo and is characterised by the appearance of skin nodules on all body surfaces including the udder (FAO, 2017)."@en ;
    skos:prefLabel "Maladie de la peau nodulaire"@fr ;
    skos:prefLabel "Enfermedad de la piel nodular"@es ;
    skos:prefLabel "dermatosi nodulare bovina"@it ;
    skos:prefLabel "Болезнь с узлами на коже"@ru ;
    skos:prefLabel "牛结节病"@ch ;
    skos:prefLabel "Knoppenhuidziekte"@nl .

ex:nuclear_agents a skos:Concept ;
    skos:prefLabel "Nuclear Agents"@en ;
    skos:definition "Nuclear agents are derived from neutron radiation (n) which is a neutron emitted by an unstable nucleus, in particular during atomic fission and nuclear fusion. Apart from a component in cosmic rays, neutrons are usually produced artificially. Because they are electrically neutral particles, neutrons can be very penetrating and when they interact with matter or tissue, they cause the emission of beta- and gamma-radiation. Neutron radiation therefore requires heavy shielding to reduce exposure (IAEA, 2004)."@en ;
    skos:prefLabel "agents nucléaires"@fr ;
    skos:prefLabel "agentes nucleares"@es ;
    skos:prefLabel "agenti nucleari"@it ;
    skos:prefLabel "ядерні агенти"@ua ;
    skos:prefLabel "ядерные агенты"@ru ;
    skos:prefLabel "核剂"@ch ;
    skos:prefLabel "kernagents"@nl .

ex:ice_flow a skos:Concept ;
    skos:prefLabel "Ice Flow"@en ;
    skos:definition "Ice flow is the motion of ice driven by gravitational forces, ice stress or, for sea ice, wind, water currents and tide (AMS, 2012)."@en ;
    skos:prefLabel "écoulement de glace"@fr ;
    skos:prefLabel "flujo de hielo"@es ;
    skos:prefLabel "flusso di ghiaccio"@it ;
    skos:prefLabel "поток льда"@ru ;
    skos:prefLabel "冰流"@ch ;
    skos:prefLabel "ijsstroom"@nl .

ex:submarine_gravitational_mass_movement_landslide a skos:Concept ;
    skos:prefLabel "Submarine Gravitational Mass Movement (‘Landslide’)"@en ;
    skos:definition "A submarine gravitational mass movement (‘Landslide’) is  the downslope movement of sediment or rock due to gravity, occurring when the downslope forces exceed the sediment's resistance to movement (Adapted from Lee et al., 2007)."@en ;
    skos:prefLabel "glissement de masse sous-marin"@fr ;
    skos:prefLabel "deslizamiento de masa submarino"@es ;
    skos:prefLabel "Frana sottomarina"@it ;
    skos:prefLabel "Підводний зсув"@ua ;
    skos:prefLabel "Подводный оползень"@ru ;
    skos:prefLabel "海底滑坡"@ch ;
    skos:prefLabel "onderzeeme massabeweging"@nl .

ex:fungal_plant_disease a skos:Concept ;
    skos:prefLabel "Fungal Plant Disease"@en ;
    skos:definition "Fungal plant disease is the occurrence of plant diseases caused by fungal agents over large areas with significant impacts on crop productivity or natural habitats (adapted from Arneson, 2001 and Moore et al., 2019)."@en ;
    skos:prefLabel "maladie fongique des plantes"@fr ;
    skos:prefLabel "malattia fungina delle piante"@it ;
