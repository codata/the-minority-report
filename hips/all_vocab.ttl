    skos:prefLabel "radio- en andere telecommunicatiefouten"@nl .

ex:flooding a skos:Concept ;
    skos:prefLabel "Flooding"@en ;
    skos:definition "Flooding is (1) an overflowing by water of the normal confines of a watercourse or other body of water; (2) an accumulation of drainage water over areas which are not normally submerged; (3) a controlled spreading of water for irrigation (WMO and UNESCO, 2012)."@en ;
    skos:prefLabel "inondation"@fr ;
