    skos:prefLabel "乙型肝炎"@ch ;
    skos:prefLabel "Hepatitis B"@nl .

ex:rock_debris_and_earth_spreads_including_landscape_creep a skos:Concept ;
    skos:prefLabel "Rock, debris and earth spreads (including landscape creep)"@en ;
    skos:definition "Rock spread: Near-horizontal stretching (elongation) of a mass of coherent blocks of rock as a result of intensive deformation of an underlying weak material, or by multiple retrogressive sliding controlled by a weak basal surface. Usually with fairly limited total displacement and slow movement (Hungr et al., 2014)."@en ;
    skos:prefLabel "Étalement rocheux, de débris et de terre (y compris le fluage du versant)"@fr ;
    skos:prefLabel "desplazamiento de rocas, escombros y tierra (incluido el creep del paisaje)"@es ;
