    skos:prefLabel "enfermedad del virus de Marburg"@es ;
    skos:prefLabel "malattia da virus di Marburg"@it ;
    skos:prefLabel "马尔堡病毒病"@ch ;
    skos:prefLabel "Marburgvirusziekte"@nl .

ex:meteorite_impact a skos:Concept ;
    skos:prefLabel "Meteorite Impact"@en ;
    skos:definition "A meteorite is an object that survives a trip through Earth’s atmosphere and hits the ground (adapted from NASA, no date)."@en ;
    skos:prefLabel "Impact de météorite"@fr ;
    skos:prefLabel "Impacto de meteorito"@es ;
    skos:prefLabel "Impatto di meteorite"@it ;
    skos:prefLabel "Удар метеорита"@ua ;
    skos:prefLabel "метеоритный удар"@ru ;
    skos:prefLabel "陨石撞击"@ch ;
    skos:prefLabel "Meteorietinslag"@nl .

ex:ebola a skos:Concept ;
    skos:prefLabel "Ebola"@en ;
    skos:definition "Ebola virus disease (EVD) is a rare but severe zoonotic viral infectious disease caused by the Ebola virus. It can be characterized by haemorrhagic fever and is often fatal in humans. EVD can trigger epidemics with high case-fatality rates (WHO, 2025)."@en ;
    skos:prefLabel "Ébola"@fr ;
    skos:prefLabel "Ébola"@es ;
    skos:prefLabel "Ebola"@it ;
    skos:prefLabel "Ебола"@ua ;
    skos:prefLabel "Эбола"@ru ;
    skos:prefLabel "埃博拉"@ch ;
    skos:prefLabel "Ebola"@nl .

ex:zoonotic_diseases a skos:Concept ;
    skos:prefLabel "Zoonotic Diseases"@en ;
    skos:definition "Zoonotic diseases, or zoonoses, are diseases shared between animals – including livestock, wildlife, and pets – and people. They can pose serious risks to both animal and human health and may have far-reaching impacts on economies and livelihoods and represent a major public health problem. Zoonotic diseases are commonly spread at the human-animal-environment interface – where people and animals interact with each other in their shared environment (adapted from WHO, FAO, WOAH, 2019 & WHO, 2020)."@en ;
    skos:prefLabel "maladies zoonotiques"@fr ;
    skos:prefLabel "enfermedades zoonóticas"@es ;
    skos:prefLabel "Zoonosi"@it ;
    skos:prefLabel "зоонозні захворювання"@ua ;
    skos:prefLabel "зоонозы"@ru ;
    skos:prefLabel "人畜共患病"@ch ;
    skos:prefLabel "zoonotische ziekten"@nl .

ex:tornado a skos:Concept ;
    skos:prefLabel "Tornado"@en ;
    skos:definition "A tornado is a rotating column of air extending from the base of a cumuliform cloud and often visible as a condensation funnel in contact with the ground, and/or attendant circulating dust or debris cloud at the ground (WMO, 2017)."@en ;
    skos:prefLabel "tornade"@fr ;
    skos:prefLabel "tornado"@es ;
    skos:prefLabel "tornado"@it ;
    skos:prefLabel "торнадо"@ua ;
    skos:prefLabel "торнадо"@ru ;
    skos:prefLabel "龙卷风"@ch ;
    skos:prefLabel "tornado"@nl .

ex:financial_shock a skos:Concept ;
    skos:prefLabel "Financial shock"@en ;
    skos:definition "A financial shock is an unexpected disturbance which originates from the financial sector and has a significant effect on an economy (e.g. national, regional, or global). The term is largely used to refer to events which have negative impacts (ECB, 2013)."@en ;
    skos:prefLabel "choc financier"@fr ;
    skos:prefLabel "choque financiero"@es ;
    skos:prefLabel "shock finanziario"@it ;
    skos:prefLabel "фінансовий шок"@ua ;
    skos:prefLabel "финансовый шок"@ru ;
    skos:prefLabel "金融冲击"@ch ;
    skos:prefLabel "financiële schok"@nl .

ex:leptospirosis a skos:Concept ;
    skos:prefLabel "Leptospirosis"@en ;
    skos:definition "Leptospirosis is an infectious disease caused by a pathogenic bacterium of the genusLeptospira. These bacteria called leptospires affect both humans and animals. Humans become infected through direct contact with the urine of infected animals or with a urine-contaminated environment which can lead to serious and sometimes fatal disease (adapted from WHO & ILS, 2003)."@en ;
    skos:prefLabel "leptospirose"@fr ;
    skos:prefLabel "leptospirosis"@es ;
    skos:prefLabel "leptospirosi"@it ;
    skos:prefLabel "лептоспіроз"@ua ;
    skos:prefLabel "лептоспироз"@ru ;
    skos:prefLabel "钩端螺旋体病"@ch ;
    skos:prefLabel "leptospirose"@nl .

ex:river_erosion_and_accretion a skos:Concept ;
    skos:prefLabel "River Erosion and Accretion"@en ;
    skos:definition "River erosion is the removal of material from the banks and beds of rivers and streams (cf. Lawler, 1993). River accretion is the formation of new land such as channel bars, sandbanks and deltas by sedimentation or changing river flow (after Islam and Guchhait, 2020 and Hasanuzzaman et al., 2024)."@en ;
    skos:prefLabel "Érosion fluviale et accretion fluviale"@fr ;
    skos:prefLabel "erosión y acreción fluvial"@es ;
    skos:prefLabel "річкова ерозія та акреція"@ua ;
    skos:prefLabel "размыв и аккумуляция рек"@ru ;
    skos:prefLabel "河流侵蚀与淤积"@ch ;
    skos:prefLabel "Riviererosie en accretie"@nl .

ex:fluoride_and_iodineiodide_excess_or_inadequate_intake a skos:Concept ;
    skos:prefLabel "Fluoride and Iodine/Iodide Excess or Inadequate Intake"@en ;
    skos:definition "Fluoride is a naturally occurring mineral to which the public are often exposed via drinking water. Depending on dose intake, fluoride may have both beneficial effects (reducing the incidence of dental caries) or negative effects (causing tooth enamel and skeletal fluorosis following prolonged high exposure) (adapted from NCBI, 2020 and WHO, no date). Some water supplies are fluoridated in order to achieve improved dental health."@en ;
    skos:prefLabel "Excès ou insuffisance d'apport en fluorure et iode/iodure"@fr ;
    skos:prefLabel "Exceso o insuficiencia de ingesta de fluoruro e yodo/ioduro"@es ;
    skos:prefLabel "Eccesso o insufficiente assunzione di fluoro e iodio/ioduro"@it ;
    skos:prefLabel "氟化物和碘/碘化物过量或摄入不足"@ch ;
    skos:prefLabel "Overmaat of onvoldoende inname van fluoride en ijood/iodide"@nl .

ex:microplastics a skos:Concept ;
    skos:prefLabel "Microplastics"@en ;
    skos:definition "Microplastics are small plastic pieces less than five millimetres in length which can be harmful to the environment, especially marine life. They originate from a variety of sources, including larger plastic debris that degrade into progressively smaller pieces (adapted from UNEP, 2016 and NOAA, 2023)."@en ;
    skos:prefLabel "Microplastiques"@fr ;
    skos:prefLabel "Microplásticos"@es ;
    skos:prefLabel "Microplastiche"@it ;
    skos:prefLabel "Мікропластик"@ua ;
    skos:prefLabel "Микропластик"@ru ;
    skos:prefLabel "微塑料"@ch ;
    skos:prefLabel "Microplastics"@nl .

ex:bridge_failure a skos:Concept ;
    skos:prefLabel "Bridge Failure"@en ;
    skos:definition "Bridge failure is the inability of a bridge, or its components, to perform as specified by its design and construction requirements (Wardhana and Hadipriono, 2003)."@en ;
    skos:prefLabel "Défaillance de pont"@fr ;
    skos:prefLabel "Falla de puente"@es ;
    skos:prefLabel "Guasto strutturale del ponte"@it ;
    skos:prefLabel "桥梁失效"@ch ;
    skos:prefLabel "Brugfalen"@nl .

ex:biodiversity_loss a skos:Concept ;
    skos:prefLabel "Biodiversity Loss"@en ;
    skos:definition "Biodiversity loss refers to the reduction of any aspect of biological diversity (i.e. diversity at the genetic, species and ecosystem levels) in a particular area through death (including extinction), destruction or manual removal. It can occur at many scales, from global extinctions to local population extinctions, leading to a decline in total diversity at the same scale."@en ;
    skos:prefLabel "Perte de biodiversité"@fr ;
    skos:prefLabel "Pérdida de biodiversidad"@es ;
    skos:prefLabel "Perdita di biodiversità"@it ;
