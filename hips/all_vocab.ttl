ex:aflatoxins a skos:Concept ;
    skos:prefLabel "Aflatoxins"@en ;
    skos:definition "Aflatoxins are mycotoxins – toxic compounds that are naturally produced by certain types of mould (fungi). Aflatoxins are among the most poisonous mycotoxins and are produced by certain moulds (Aspergillus flavus and A. parasiticus) that grow in soil, decaying vegetation, hay, and grains. Aflatoxins pose a serious health risk to humans and livestock (WHO, 2023)."@en ;
    skos:prefLabel "aflatoxines"@fr ;
    skos:prefLabel "aflatoxinas"@es ;
    skos:prefLabel "aflatossine"@it ;
    skos:prefLabel "афлатоксини"@ua ;
    skos:prefLabel "афлатоксины"@ru ;
    skos:prefLabel "黄曲霉毒素"@ch ;
    skos:prefLabel "aflatoxine"@nl .

ex:crimean_congo_haemorrhagic_fever a skos:Concept ;
    skos:prefLabel "Crimean-Congo Haemorrhagic Fever"@en ;
    skos:definition "Crimean-Congo haemorrhagic fever (CCHF) is a tick-borne viral infection caused by the CCHF virus. It causes severe viral haemorrhagic fever outbreaks and epidemics. CCHF outbreaks have a case fatality rate of 10-40% (WHO, 2025)."@en ;
    skos:prefLabel "Fièvre hémorragique de Crimée-Congo"@fr ;
    skos:prefLabel "Fiebre hemorrágica de Crimea-Congo"@es ;
    skos:prefLabel "Febbre emorragica di Crimea-Congo"@it ;
    skos:prefLabel "Кримсько-Конго геморрагічна вірусна хвороба"@ua ;
    skos:prefLabel "克里米亚–刚果出血热"@ch ;
    skos:prefLabel "Crimean-Congo hemorragische koorts"@nl .

ex:non_international_armed_conflict_niac a skos:Concept ;
    skos:prefLabel "Non-International Armed Conflict (NIAC)"@en ;
    skos:definition "It is widely accepted today that two key conditions must be met for a situation of violence to be considered a Non-International Armed Conflict (NIAC) and therefore subject to International humanitarian law (IHL): the non-state party/parties must be organized, and the violence between the parties must be sufficiently intense. The existence of a NIAC is not predicated on any other threshold or condition. In particular, political or other motivations of the parties play no role in the classification of a conflict. (adapted from ICRC, 2024)"@en ;
    skos:prefLabel "Conflit armé non international"@fr ;
    skos:prefLabel "Conflicto armado no internacional"@es ;
    skos:prefLabel "Conflitto armato non internazionale"@it ;
    skos:prefLabel "Неінтернаціональний збройний конфлікт"@ua ;
    skos:prefLabel "Немеждународный вооружённый конфликт"@ru ;
    skos:prefLabel "非国际武装冲突"@ch ;
    skos:prefLabel "Niet-internationaal gewapend conflict"@nl .

ex:gale_strong_gale a skos:Concept ;
    skos:prefLabel "Gale (Strong Gale)"@en ;
