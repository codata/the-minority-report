ex:peste_des_petits_ruminants a skos:Concept ;
    skos:prefLabel "Peste Des Petits Ruminants"@en ;
    skos:definition "Peste des petits ruminants is a highly contagious and devastating disease of goats and sheep. The causative agent, Peste des petits ruminants virus, is a member of the genusMorbillivirus, FamilyParamyxoviridaeand OrderMononegavirales(adapted from FAO, no date and WOAH, 2024a)."@en ;
    skos:prefLabel "Peste des petits ruminants"@fr ;
    skos:prefLabel "Peste de los pequeños rumiantes"@es ;
    skos:prefLabel "Peste dei piccoli ruminanti"@it ;
