ex:near_earth_object a skos:Concept ;
    skos:prefLabel "Near-Earth Object"@en ;
    skos:definition "A near-Earth object (NEO) is an asteroid or comet whose trajectory brings it to within 1.3 astronomical units of the Sun and hence within 0.3 astronomical units, or approximately 45 million kilometres, of the Earth’s orbit (UN OOSA, no date)."@en ;
    skos:prefLabel "Objet proche de la Terre"@fr ;
    skos:prefLabel "Objeto cercano a la Tierra"@es ;
    skos:prefLabel "Oggetto vicino alla Terra"@it ;
    skos:prefLabel "Об'єкт, близький до Землі"@ua ;
    skos:prefLabel "Объект, близкий к Земле"@ru ;
    skos:prefLabel "近地天体"@ch ;
    skos:prefLabel "nabije aardobject"@nl .

ex:trypanosomiasis a skos:Concept ;
    skos:prefLabel "Trypanosomiasis"@en ;
    skos:definition "Trypanosomiasis, human African (sleeping sickness) and animal trypanosomosis (nagana) are caused by protozoan parasites belonging to the genus Trypanosoma transmitted by infected tsetse flies and is endemic in sub-Saharan Africa. Without treatment, the disease is considered fatal (adapted from WHO, 2023 and FAO, no date)."@en ;
    skos:prefLabel "trypanosomiase"@fr ;
    skos:prefLabel "tripanosomiasis"@es ;
    skos:prefLabel "trypanosomiasi"@it ;
    skos:prefLabel "трипаносоміаз"@ua ;
    skos:prefLabel "трипаносомоз"@ru ;
    skos:prefLabel "锥虫病"@ch ;
    skos:prefLabel "trypanosomiasis"@nl .

ex:reservoir_flooding a skos:Concept ;
    skos:prefLabel "Reservoir Flooding"@en ;
    skos:definition "Man-made reservoirs, sometimes called artificial lakes, are important water sources in many countries around the world. In contrast to natural processes of lake formation, reservoirs are artificial, usually formed by constructing a dam across a river or by diverting a part of the river flow and storing the water in a reservoir. Reservoir flooding occurs as an uncontrolled release of water if a dam or reservoir fails (adapted from UNEP, 2000 and Defra and EA, 2014)."@en ;
    skos:prefLabel "inondation de réservoir"@fr ;
    skos:prefLabel "inundación por rotura de presa"@es ;
    skos:prefLabel "inondazione di bacino"@it ;
    skos:prefLabel "прорыв плотины"@ru ;
    skos:prefLabel "水库洪水"@ch ;
    skos:prefLabel "reservoiroverstroming"@nl .

ex:lava_flows_and_domes a skos:Concept ;
    skos:prefLabel "Lava Flows and Domes"@en ;
    skos:definition "Lava flows and lava domes form from molten rock that erupts and cools on or near the Earth’s surface. A lava flow is an outpouring of fluid, relatively low-viscosity molten rock, whereas a lava dome is a pile of relatively viscous lava that cannot flow far from the vent (cf. Dietterich et al., 2025; Harnett et al., 2025), the collapse of which may be hazardous."@en ;
    skos:prefLabel "Coulées et dômes de lave"@fr ;
    skos:prefLabel "Flujos de lava y domos de lava"@es ;
    skos:prefLabel "Flussi di lava e domi di lava"@it ;
    skos:prefLabel "Лавові потоки та куполи"@ua ;
    skos:prefLabel "Потоки лавы и купола лавы"@ru ;
    skos:prefLabel "熔岩流和熔岩穹丘"@ch ;
    skos:prefLabel "Lavastromen en lava-koepels"@nl .

ex:haze a skos:Concept ;
    skos:prefLabel "Haze"@en ;
    skos:definition "Haze is a suspension in the air of extremely small, dry particles invisible to the naked eye and sufficiently numerous to give the air an opalescent appearance (WMO, 2017)."@en ;
    skos:prefLabel "brume"@fr ;
    skos:prefLabel "Calima"@es ;
    skos:prefLabel "nebbia"@it ;
    skos:prefLabel "Смог"@ua ;
    skos:prefLabel "дымка"@ru ;
    skos:prefLabel "霾"@ch ;
    skos:prefLabel "nevel"@nl .

ex:groundwater_flooding a skos:Concept ;
    skos:prefLabel "Groundwater Flooding"@en ;
    skos:definition "A groundwater flood is the emergence of groundwater at the ground surface away from perennial river channels or the rising of groundwater into man-made ground, under conditions where the ‘normal’ ranges of groundwater level and groundwater flow are exceeded (BGS, 2010)."@en ;
    skos:prefLabel "Inondation par nappe phréatique"@fr ;
    skos:prefLabel "inundación por aguas subterráneas"@es ;
    skos:prefLabel "затоплення ґрунтовими водами"@ua ;
    skos:prefLabel "地下水洪水"@ch ;
    skos:prefLabel "grondwateroverstroming"@nl .

ex:ponding_drainage_flooding a skos:Concept ;
    skos:prefLabel "Ponding (Drainage) Flooding"@en ;
    skos:definition "A ponding flood is a flood that results from rainwater ponding at or near the point where it falls because it is falling faster than the drainage system (natural or man-made) can carry it away (WMO, 2006)."@en ;
    skos:prefLabel "inondation de type ponding"@fr ;
    skos:prefLabel "Inundación por acumulación"@es ;
    skos:prefLabel "Inondazione da ristagno"@it ;
    skos:prefLabel "Затоплення від застою води"@ua ;
    skos:prefLabel "Затопление от застоя воды"@ru ;
    skos:prefLabel "积水洪水"@ch ;
    skos:prefLabel "Platte wateroverlast"@nl .

ex:tropical_cyclone a skos:Concept ;
    skos:prefLabel "Tropical Cyclone"@en ;
    skos:definition "A tropical cyclone is a cyclone of tropical origin of small diameter (some hundreds of kilometres) with a minimum surface pressure in some cases of less than 900 hPa, very violent winds and torrential rain; sometimes accompanied by thunderstorms. It usually contains a central region, known as the 'eye' of the storm, with a diameter of the order of some tens of kilometres, and with light winds and a more or less lightly clouded sky (WMO, 2023)."@en ;
    skos:prefLabel "cyclone tropical"@fr ;
    skos:prefLabel "ciclón tropical"@es ;
    skos:prefLabel "ciclone tropicale"@it ;
    skos:prefLabel "тропічний циклон"@ua ;
    skos:prefLabel "тропический циклон"@ru ;
    skos:prefLabel "热带气旋"@ch ;
    skos:prefLabel "tropische cycloon"@nl .

ex:shrimp_disease_bacterial_acute_hepatic_pancreatic_necrosis a skos:Concept ;
    skos:prefLabel "Shrimp disease (bacterial) - Acute Hepatic Pancreatic Necrosis"@en ;
    skos:definition "Shrimp acute hepatopancreatic necrosis disease (AHPND) is caused by virulent strains ofVibrio parahaemolyticusand related Vibrio species. AHPND-associated mortalities occur early in the production cycle, usually within 30 to 35 days of stocking, and because of this AHPND was initially referred to as early mortality syndrome (WOAH, 2023)."@en ;
    skos:prefLabel "Nécrose hépatopancréatique aiguë"@fr ;
    skos:prefLabel "Necrosis hepato‑pancreática aguda"@es ;
    skos:prefLabel "Гостра гепатопанкреатична некротична хвороба креветок"@ua ;
    skos:prefLabel "Острая гепатопанкреатическая некротическая болезнь креветок"@ru ;
    skos:prefLabel "急性肝胰腺坏死症"@ch .

ex:disaster_and_conflict_waste a skos:Concept ;
    skos:prefLabel "Disaster and Conflict Waste"@en ;
    skos:definition "Disaster and conflict waste is the waste generated by the impact of a disaster or conflict, both as a direct effect of the disaster or conflict as well as in the post-disaster and post-conflict phase as a result of poor waste management (UNEP/OCHA, 2011)."@en ;
    skos:prefLabel "Déchets dus aux désastres et conflits"@fr ;
    skos:prefLabel "Residuos generados por desastres y conflictos"@es ;
    skos:prefLabel "Rifiuti derivanti da disastri e conflitti"@it ;
    skos:prefLabel "Відходи від лих та конфліктів"@ua ;
    skos:prefLabel "Отходы от стихийных бедствий и конфликтов"@ru ;
    skos:prefLabel "灾害与冲突废弃物"@ch ;
    skos:prefLabel "Ramp- en conflictafval"@nl .

ex:drain_and_sewer_flooding a skos:Concept ;
    skos:prefLabel "Drain and Sewer Flooding"@en ;
    skos:definition "Drain and sewer flooding is said to occur when sewage or foul water leaks from the sewerage system (through pipes, drains or manholes) or floods up through toilets, sinks or showers inside a building (Priestly, 2016)."@en ;
    skos:prefLabel "Inondation des réseaux d'assainissement"@fr ;
    skos:prefLabel "Затопление дренажных систем и канализации"@ru ;
    skos:prefLabel "排水和下水道洪水"@ch .

ex:supply_chain_failure a skos:Concept ;
    skos:prefLabel "Supply Chain Failure"@en ;
    skos:definition "Supply chain failure refers to an event in the supply chain that disrupts the flow of materials on their journey from initial suppliers through to final customers (Walters, 2007)."@en ;
    skos:prefLabel "Fallo de la cadena de suministro"@es ;
    skos:prefLabel "fallimento della catena di approvvigionamento"@it ;
    skos:prefLabel "збій ланцюга постачання"@ua ;
    skos:prefLabel "сбой цепочки поставок"@ru ;
    skos:prefLabel "供应链中断"@ch ;
    skos:prefLabel "Falen van de toeleveringsketen"@nl .

ex:snakebite_envenoming a skos:Concept ;
    skos:prefLabel "Snakebite envenoming"@en ;
    skos:definition "A snakebite envenoming is a potentially life-threatening disease caused by toxins in the bite of a venomous snake (WHO, 2023)."@en ;
    skos:prefLabel "envenimation par morsure de serpent"@fr ;
    skos:prefLabel "envenenamiento por mordedura de serpiente"@es ;
