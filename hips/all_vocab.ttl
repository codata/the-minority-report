ex:dengue a skos:Concept ;
    skos:prefLabel "Dengue"@en ;
    skos:definition "Dengue is a mosquito-borne disease that is caused by a virus of the Flaviviridae family and transmitted by female mosquitoes mainly of the species Aedes aegypti and, to a lesser extent, A. albopictus. The incidence of dengue has grown dramatically around the world in recent decades, with cases reported to WHO increasing from 505 430 cases in 2000 to 5.2 million in 2019 (adapted from WHO, 2024)."@en ;
    skos:prefLabel "dengue"@fr ;
    skos:prefLabel "dengue"@es ;
    skos:prefLabel "dengue"@it ;
    skos:prefLabel "денге"@ua ;
    skos:prefLabel "денге"@ru ;
    skos:prefLabel "登革热"@ch ;
    skos:prefLabel "dengue"@nl .

ex:earthquake a skos:Concept ;
    skos:prefLabel "Earthquake"@en ;
    skos:definition "Earthquake is a term used to describe the sudden slip on a fault and the ground shaking that occurs from the radiated seismic energy during the slipping event. The sudden slip can be caused by stress changes in the earth or volcanic/magmatic activity (USGS, no date)."@en ;
    skos:prefLabel "séisme"@fr ;
    skos:prefLabel "terremoto"@es ;
    skos:prefLabel "terremoto"@it ;
    skos:prefLabel "землетрус"@ua ;
    skos:prefLabel "землетрясение"@ru ;
    skos:prefLabel "地震"@ch ;
    skos:prefLabel "aardbeving"@nl .

ex:forest_declines_and_diebacks a skos:Concept ;
    skos:prefLabel "Forest Declines and Diebacks"@en ;
    skos:definition "Forest declines and diebacks are episodic events characterised by premature, progressive loss of tree and stand vigour and health over a given period without obvious evidence of a single clearly identifiable causal factor such as physical disturbance or attack by primary disease or insect (Ciesla & Donaubauer, 1994)."@en ;
    skos:prefLabel "Déclin et dépérissement des forêts"@fr ;
    skos:prefLabel "Declive y mortandad forestal"@es ;
    skos:prefLabel "declino forestale e decadimento"@it ;
    skos:prefLabel "Занепад та відмирання лісів"@ua ;
    skos:prefLabel "Ослабление и отмирание лесов"@ru ;
    skos:prefLabel "森林衰退与枯死"@ch ;
    skos:prefLabel "Bosachteruitgang en -sterfte"@nl .

ex:wind a skos:Concept ;
    skos:prefLabel "Wind"@en ;
    skos:definition "Wind is air motion relative to the Earth’s surface. Unless otherwise specified, only the horizontal component is considered (WMO, 1992)."@en ;
    skos:prefLabel "vent"@fr ;
    skos:prefLabel "viento"@es ;
    skos:prefLabel "vento"@it ;
    skos:prefLabel "вітер"@ua ;
    skos:prefLabel "ветер"@ru ;
    skos:prefLabel "风"@ch ;
    skos:prefLabel "wind"@nl .

ex:marburg_virus_disease a skos:Concept ;
    skos:prefLabel "Marburg virus disease"@en ;
    skos:definition "Marburg virus disease (MVD), formerly known as Marburg haemorrhagic fever, is a severe, often fatal illness in humans. The virus causes severe viral haemorrhagic fever in humans (WHO, 2025)."@en ;
