ex:snakebite_envenoming a skos:Concept ;
    skos:prefLabel "Snakebite envenoming"@en ;
    skos:definition "A snakebite envenoming is a potentially life-threatening disease caused by toxins in the bite of a venomous snake (WHO, 2023)."@en ;
    skos:prefLabel "envenimation par morsure de serpent"@fr ;
    skos:prefLabel "envenenamiento por mordedura de serpiente"@es ;
    skos:prefLabel "Отруєння зміїним укусом"@ua ;
    skos:prefLabel "蛇咬中毒"@ch ;
    skos:prefLabel "slangenbeetvergiftiging"@nl .
