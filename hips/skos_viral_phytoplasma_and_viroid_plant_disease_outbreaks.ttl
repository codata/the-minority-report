@prefix ex: <http://theminorityreport.org/vocab/> .

ex:viral_phytoplasma_and_viroid_plant_disease_outbreaks a skos:Concept ;
    skos:prefLabel "Viral, Phytoplasma and Viroid Plant Disease Outbreaks"@en ;
    skos:definition "Viral, phytoplasma and viroid plant disease outbreaks refer to sudden occurrence of plant diseases caused by viruses, phytoplasma (syn. mycoplasma-like organisms) and viroids over large areas with significant impact on crop production or natural habitats (adapted from Nakashima & Murata, 1993; Hammond & Owens, 2006; FAO / IPPC, 2016; Rubio et al., 2020)."@en ;
    skos:prefLabel "Brote de enfermedades virales, fitoplasmáticas y por viroides de las plantas"@es ;
    skos:prefLabel "Epidemie di malattie delle piante dovute a virus, fitoplasmidi e viroidi"@it ;
    skos:prefLabel "Спалахи вірусних, фітоплазмових та віроїдних хвороб рослин"@ua ;
    skos:prefLabel "Вспышки вирусных, фитоплазменных и вироидных болезней растений"@ru ;
    skos:prefLabel "Uitbraken van virale, fytoplasmische en viroïdale plantenziekten"@nl .
