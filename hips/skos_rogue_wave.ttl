@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://theminorityreport.org/vocab/> .

ex:rogue_wave a skos:Concept ;
    skos:prefLabel "Rogue Wave"@en ;
    skos:definition "Rogue waves are extreme waves with overall or crest heights that are abnormally high relative to the background significant wave height (WMO, 2018)."@en ;
    skos:prefLabel "vague rogue"@fr ;
    skos:prefLabel "ola anómala"@es ;
    skos:prefLabel "onda anomala"@it ;
    skos:prefLabel "Аномальна хвиля"@ua ;
    skos:prefLabel "Аномальная волна"@ru ;
    skos:prefLabel "怪浪"@ch ;
    skos:prefLabel "rogue wave"@nl .
