  "isBasedOn": [
    {
      "@type": "CreativeWork",
      "@id": "source_GH0101_Earthquake_html",
      "name": "GH0101_Earthquake.html",
      "description": "Original UNDRR/ISC Hazard Information Profile (HIPS) page for GH0101: Earthquake. This self-contained HTML document (base64-encoded) preserves the full authoritative content as published at https://www.preventionweb.net/understanding-disaster-risk/terminology/hips/gh0101. It includes: (1) the official SKOS concept definition with skos:prefLabel, skos:definition, skos:scopeNote, skos:broader, and skos:altLabel; (2) structured JSON-LD metadata embedded in a <script type='application/ld+json'> block; (3) thematic sections covering hazard drivers, impacts, risk metrics, multi-hazard context, monitoring/early-warning guidance, and risk management measures; (4) bibliographic references and provenance (dct:source, prov:wasQuotedFrom, prov:wasInfluencedBy). Parsing Tip: The core technical content can be extracted from the HTML structure by targeting the <article class='custom-full-content'> (or fallback <div class='main-container'>) container and decomposing boilerplate script, style, noscript, and iframe tags. Section titles follow repeated patterns: major sections use <h2> and <h3> tags with class 'field-label-above' or 'field-group-title' (e.g., 'Primary reference(s)', 'Annotations', 'Drivers', 'Impacts', 'Risk Management', 'Monitoring', 'References'), and inline field labels use <div> with class 'field--label' or 'field-label-inline' (e.g., 'Unique identifier / Notation', 'Synonyms', 'Definition'). Intended uses: AI model training on technical disaster-risk terminology, multilingual controlled-vocabulary generation, information extraction, and semantic enrichment of the UNDRR-ISC Hazard Information Profiles dataset.",
      "contentUrl": "hips/GH0101/data/distribution/GH0101_Earthquake.html",
      "encodingFormat": "text/html",
      "sha256": "640b9a9ba27714eed70e81f5ad5ee4740670ba4353b5093a0b19268790e2a331"
    },
    {
      "@type": "CreativeWork",
      "@id": "clean_text_source_GH0101_Earthquake_html",
      "name": "GH0101_Earthquake_clean.txt",
      "description": "Clean plaintext extract of the original HIPS HTML document for GH0101, omitting template headers, footers, navigation, styles, and scripts. BS4 Extraction Pattern: (1) Title: soup.find('title').get_text().strip(), (2) Date: soup.find('meta', property='article:published_time')['content'] (or name='vf:date-published-v2' / 'vf:date-published'), (3) Article Content: soup.find('article', class_='custom-full-content') (scripts, styles, noscript, and iframe tags decomposed).",
      "contentUrl": "hips/GH0101/data/distribution/GH0101_Earthquake_clean.txt",
      "encodingFormat": "text/plain",
      "sha256": "5998520146b1d93ca3be19c4f9864c2ab3d1f4c01104cb8947b44fc9bdc28a35"
