ex:EN0106 a skos:Concept ;
    skos:prefLabel "Runoff / Nonpoint Source Pollution"@en ;
    skos:definition "Nonpoint sources of pollution refer to pollution that does not have a single point of origin or has not been introduced into a receiving freshwater or maritime environment from a specific outlet. The pollutants are generally carried off from the land by agricultural runoff, urban stormwater, atmospheric deposition or subaqueous groundwater discharges. The most common categories of nonpoint pollution are agriculture, forestry, urban areas, mining, construction, dams and channels, land disposal and saltwater intrusion."@en ;
    skos:prefLabel "odtočak / netočni izvor zagađenja"@hr ;
    skos:prefLabel "afstrømning / ikke-punktkildesforurening"@da ;
    skos:prefLabel "afvoer / niet-puntvervuiling"@nl ;
