ex:BI0101 a skos:Concept ;
    skos:prefLabel "Airborne Diseases"@en ;
    skos:definition "Airborne transmission of infectious agents refers to the transmission of disease caused by the dissemination of very small droplets that remain infectious when suspended in air over long distances and time, and potentially cause significant morbidity and mortality (adapted from WHO, 2020)."@en ;
