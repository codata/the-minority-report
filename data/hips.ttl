ex:GH0204 a skos:Concept ;
    skos:prefLabel "Pyroclastic Density Current"@en ;
    skos:definition "Pyroclastic density currents are hot, fast-moving mixtures of volcanic particles and gas that flow according to their density relative to the surrounding medium and the Earth's gravity. They typically originate from the gravitational collapse of explosive eruption columns, lava domes or lava-flow fronts, and explosive lateral blasts (cf. Charbonnier et al., 2025)."@en ;
