ex:GH0302 a skos:Concept ;
    skos:prefLabel "Rock, debris and earth spreads (including landscape creep)"@en ;
    skos:definition "Rock spread: Near-horizontal stretching (elongation) of a mass of coherent blocks of rock as a result of intensive deformation of an underlying weak material, or by multiple retrogressive sliding controlled by a weak basal surface. Usually with fairly limited total displacement and slow movement (Hungr et al., 2014)."@en ;
    skos:prefLabel "разпространение на скали, обломъци и земя (включително ландшафтна течка)"@bg ;
    skos:prefLabel "spredning af klipper, affald og jord (inkl. landskabscreep)"@da ;
    skos:prefLabel "verspreiding van rotsen, resten en aarde (inclusief landschapcreep)"@nl ;
    skos:prefLabel "Rock, debris and earth spreads (including landscape creep)"@en ;
    skos:prefLabel "kivide, prahi ja maa levik"@et ;
    skos:prefLabel "Fels-, Schutt- und Erdbewegungen (einschließlich Landschaftscreep)"@de ;
    skos:prefLabel "διασπορά βράχων, κομματιών και εδάφους (συμπεριλαμβανομένης της 'creep' του τοπίου)"@el ;
    skos:prefLabel "spreading di rocce, detriti e terra (incluso lo creep del paesaggio)"@it ;
    skos:prefLabel "spreading ta' roċi, detriti u talja (inkludi creep tal-pajsaġġ)"@mt ;
    skos:prefLabel "espalhamento de rochas, detritos e terra (incluindo creep de paisagem)"@pt ;
    skos:prefLabel "extindere de roci, deșeuri și pământ (incluzând creep de peisaj)"@ro ;
    skos:prefLabel "rozšírenie skal, troskov a pôdy (vrátane krajinného creep)"@sk ;
    skos:prefLabel "Espiendas de rocas, escombros y tierra (incluyendo el arrastre lento del paisaje)"@es ;
    skos:prefLabel "spridning av berg, avfall och jord (inklusive landskapscreep)"@sv ;
    skos:prefLabel "岩石、碎屑和土壤扩散（包括景观蠕变）"@ch ;
    skos:prefLabel "распространение горных пород, обломков и грунта (включая ландшафтный creep)"@ru .

